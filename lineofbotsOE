-- Парсим [DO:action] из текста ИИ
-- Возвращает: actionName | nil,  cleanText (без тега и без лишних пробелов вокруг него)
-- Парсим [DO:action] из ответа ИИ
-- Тег может быть В НАЧАЛЕ, В КОНЦЕ или В СЕРЕДИНЕ текста
-- Возвращает: actionName | nil,  cleanText (без тега и лишних пробелов)
local function parseActionTag(text)
    if not text then return nil, "" end

    -- Нормализуем регистр для поиска тега: [do:wave] / [DO:wave] / [Do:Wave] → всё работает
    -- Ищем тег [DO:xxx] или [do:xxx] в любом месте
    local upperText = text:upper()
    local tagStart, tagEnd, actionUpper = upperText:find("%[DO:([%w_]+)%]")

    local action = nil
    local cleanText = text

    if tagStart then
        -- Извлекаем action из оригинального текста (сохраняем регистр, потом lower())
        action = text:sub(tagStart + 4, tagEnd - 1):lower()  -- +4 = skip "[DO:", -1 = skip "]"

        -- Убираем найденный тег из текста
        cleanText = text:sub(1, tagStart - 1) .. text:sub(tagEnd + 1)
    end

    -- Вырезаем ВСЕ оставшиеся [DO:xxx] теги (любой регистр) — чтобы они не утекали в чат
    -- Это ловит второй/третий тег если модель написала несколько
    cleanText = cleanText:gsub("%[%s*[Dd][Oo]:%s*[%w_]+%s*%]", "")

    -- Убираем двойные пробелы и пробелы по краям
    cleanText = cleanText:gsub("%s+", " "):match("^%s*(.-)%s*$") or ""

    return action, cleanText
end

-- Выполнить действие по имени. cleanText — уже очищенный текст без тега.
-- originalUserMsg — оригинальное сообщение пользователя (для умного парсинга прыжков)
local function executeAction(actionName, sourcePlayer, cleanText, originalUserMsg)
    if actionName and ClientSettings.ActionsEnabled then
        -- Умный парсинг числа прыжков: если ИИ написал [DO:jump] но в сообщении было число
        -- Например: "прыгни 5 раз" → ИИ пишет [DO:jump] → мы видим 5 → вызываем doJump(5)
        if actionName == "jump" and originalUserMsg then
            local msg = originalUserMsg:lower()
            -- Ищем число перед/после "раз", "раза", "times", "прыжк"
            local n = msg:match("(%d+)%s*ра[зза]")
                   or msg:match("(%d+)%s*прыжк")
                   or msg:match("(%d+)%s*times?")
                   or msg:match("jump%s*(%d+)")
                   or msg:match("прыгни%s*(%d+)")
            if n then
                n = math.max(1, math.min(tonumber(n) or 1, 10))
                if n > 1 then
                    task.spawn(function() doJump(n) end)
                    return cleanText or ""
                end
            end
        end

        local handler = ACTION_HANDLERS[actionName]
        if handler then
            task.spawn(function() handler(sourcePlayer) end)
        end
    end
    return cleanText or ""
end

