local function makeInput(parent, placeholder, initText)
    local wrap = frame(parent, T.BgInput)
    wrap.Size = UDim2.new(1, 0, 0, 34)
    corner(wrap, 8)
    stroke(wrap, 1, T.StrokeHard, 0)

    local box = Instance.new("TextBox")
    box.BackgroundTransparency = 1
    box.Size     = UDim2.new(1, -16, 1, 0)
    box.Position = UDim2.new(0, 8, 0, 0)
    box.Font     = T.Mono
    box.TextSize = 13
    box.TextColor3 = T.Text
    box.PlaceholderText  = placeholder or ""
    box.PlaceholderColor3 = T.TextDim
    box.TextXAlignment   = Enum.TextXAlignment.Left
    box.ClearTextOnFocus = false
    box.Text = initText or ""
    box.Parent = wrap

    box.Focused:Connect(function()
        tw(wrap, tw_fast, {BackgroundColor3 = T.BgHover})
        wrap.UIStroke.Color = T.Accent
        wrap.UIStroke.Transparency = 0.3
    end)
    box.FocusLost:Connect(function()
        tw(wrap, tw_fast, {BackgroundColor3 = T.BgInput})
        wrap.UIStroke.Color = T.StrokeHard
        wrap.UIStroke.Transparency = 0
    end)

    return wrap, box
end

-- Кнопка
local function makeBtn(parent, txt, scheme)
    scheme = scheme or "primary"
    local bg = scheme == "primary" and T.Accent
            or scheme == "danger"  and T.Red
            or T.BgCard

    local btn = frame(parent, bg, scheme == "ghost" and 0.9 or 0.1)
    btn.Size   = UDim2.new(1, 0, 0, 34)
    btn.Active = true
    corner(btn, 8)

    if scheme == "primary" then
        gradient(btn, T.Accent, T.Purple, 90)
        stroke(btn, 1, T.Accent, 0.4)
    elseif scheme == "ghost" then
        stroke(btn, 1, T.StrokeHard, 0)
    else
        stroke(btn, 1, T.Red, 0.4)
    end

    local lbl3 = label(btn, txt, 13, T.SansBold, Color3.fromRGB(255,255,255))
    lbl3.Size = UDim2.new(1,0,1,0)
    lbl3.TextXAlignment = Enum.TextXAlignment.Center

    btn.MouseEnter:Connect(function()
        tw(btn, tw_fast, {BackgroundTransparency = 0})
    end)
    btn.MouseLeave:Connect(function()
        tw(btn, tw_fast, {BackgroundTransparency = scheme == "ghost" and 0.9 or 0.1})
    end)

    return btn
end

-- Дропдаун (простой)
local function makeDropdown(parent, options, initVal, onChange)
    local current = initVal or (options[1] or "")
    local open    = false

    local wrap = frame(parent, T.BgInput)
    wrap.Size      = UDim2.new(1, 0, 0, 34)
    wrap.ClipsDescendants = false
    corner(wrap, 8)
    stroke(wrap, 1, T.StrokeHard, 0)

    local valLbl2 = label(wrap, current, 13, T.Mono, T.Text)
    valLbl2.Size     = UDim2.new(1, -30, 1, 0)
    valLbl2.Position = UDim2.new(0, 10, 0, 0)

    local arrow = label(wrap, "▾", 12, T.Sans, T.TextMid)
    arrow.Size     = UDim2.new(0, 20, 1, 0)
    arrow.Position = UDim2.new(1, -24, 0, 0)
    arrow.TextXAlignment = Enum.TextXAlignment.Center

    -- Выпадающий список
    local dropdown = frame(wrap, T.BgCard)
    dropdown.Name    = "Dropdown"
    dropdown.Size    = UDim2.new(1, 0, 0, 0)
    dropdown.Position = UDim2.new(0, 0, 1, 4)
    dropdown.ClipsDescendants = true
    dropdown.ZIndex  = 10
    dropdown.Visible = false
    corner(dropdown, 8)
    stroke(dropdown, 1, T.StrokeHard, 0)

    local ddList = scrollFrame(dropdown, 2)
    ddList.Size = UDim2.new(1, 0, 1, 0)
    ddList.ZIndex = 10
    listLayout(ddList, Enum.FillDirection.Vertical, 2)
    padding(ddList, nil, 6, 4)

    local optBtns = {}
    for _, opt in ipairs(options) do
        local ob = frame(ddList, T.BgCard, 1)
        ob.Size     = UDim2.new(1, 0, 0, 28)
        ob.Active   = true
        ob.ZIndex   = 11
        corner(ob, 6)

        local ol = label(ob, opt, 12, T.Mono, T.TextMid)
        ol.Size     = UDim2.new(1, -12, 1, 0)
        ol.Position = UDim2.new(0, 8, 0, 0)
        ol.ZIndex   = 12

        ob.MouseEnter:Connect(function()
            tw(ob, tw_fast, {BackgroundTransparency=0.5, BackgroundColor3=T.BgHover})
            tw(ol, tw_fast, {TextColor3=T.Text})
        end)
        ob.MouseLeave:Connect(function()
            local isCurrent = (ol.Text == current)
            tw(ob, tw_fast, {BackgroundTransparency=isCurrent and 0.6 or 1})
            tw(ol, tw_fast, {TextColor3=isCurrent and T.Accent or T.TextMid})
        end)
        ob.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                current = opt
                valLbl2.Text = opt
                -- Закрываем
                open = false
                tw(dropdown, tw_fast, {Size=UDim2.new(1,0,0,0)})
                task.delay(0.15, function() dropdown.Visible = false end)
                tw(arrow, tw_fast, {Rotation=0})
                if onChange then onChange(opt) end
            end
        end)
        table.insert(optBtns, {frame=ob, label=ol})
    end

    -- Размер дропдауна
    local DD_ITEM_H = 30
    local DD_PAD    = 8
    local DD_MAX    = math.min(#options, 6)
    local DD_H      = DD_MAX * DD_ITEM_H + DD_PAD

    local function toggleDropdown()
        open = not open
        dropdown.Visible = true
        if open then
            tw(dropdown, tw_med, {Size=UDim2.new(1,0,0,DD_H)})
            tw(arrow, tw_fast, {Rotation=180})
        else
            tw(dropdown, tw_fast, {Size=UDim2.new(1,0,0,0)})
            tw(arrow, tw_fast, {Rotation=0})
            task.delay(0.15, function() dropdown.Visible = false end)
        end
    end

    wrap.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            toggleDropdown()
        end
    end)

    local function setValue(v)
        current = v
        valLbl2.Text = v
    end

    return wrap, setValue
end

