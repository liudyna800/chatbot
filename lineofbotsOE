local _cachedMyNameLow = Players.LocalPlayer.Name:lower()
local _cachedMyDispLow = Players.LocalPlayer.DisplayName:lower()
Players.LocalPlayer:GetPropertyChangedSignal("DisplayName"):Connect(function()
    _cachedMyDispLow = Players.LocalPlayer.DisplayName:lower()
end)

local function processChatMessage(player, rawMessage)
    local settings = ClientSettings
    if not settings.Enabled or not settings.AutoReply then return end

    local now          = os.clock()
    local maxPerSecond = tonumber(settings.MaxMessagesPerSecond) or 3
    if maxPerSecond < 1 then maxPerSecond = 1 end
    if not _floodLastBatch then
        _floodLastBatch  = now
        _floodBatchCount = 0
    end
    if (now - _floodLastBatch) < 1 then
        _floodBatchCount = _floodBatchCount + 1
        if _floodBatchCount > maxPerSecond then return end
    else
        _floodLastBatch  = now
        _floodBatchCount = 1
    end

    if player.UserId == Players.LocalPlayer.UserId then return end
    if isBlacklisted(settings, player.UserId) then return end

    if settings.AntiSpam then
        local lastData = _lastMsgPerUser[player.UserId]
        local msgLower = rawMessage:lower():gsub("%s+", " "):match("^%s*(.-)%s*$")
        local nowTime  = os.clock()
        if lastData and lastData.text == msgLower and (nowTime - lastData.time) < 12 then return end
        _lastMsgPerUser[player.UserId] = { text = msgLower, time = nowTime }
        if (now - (_lastAntiSpamClean or 0)) > 120 then
            _lastAntiSpamClean = now
            for uid, data in pairs(_lastMsgPerUser) do
                if (now - data.time) > 60 then _lastMsgPerUser[uid] = nil end
            end
            for uid, _ in pairs(_userLangCache) do
                if not Players:GetPlayerByUserId(uid) then _userLangCache[uid] = nil end
            end
        end
    end

    local msgLowerForMention = rawMessage:lower()
    local mentionHit = settings.ReactToMention
        and (msgLowerForMention:find(_cachedMyNameLow, 1, true)
          or msgLowerForMention:find(_cachedMyDispLow, 1, true))

    if not mentionHit and not passesTrigger(settings, rawMessage) then return end

    local message = normalizeOneLine(rawMessage)
    if message == "" then return end

    if settings.Range.SelectiveMode then
        local isWhitelisted = false
        local whitelist     = settings.Range.WhitelistUserIds or {}
        for _, id in ipairs(whitelist) do
            if id == player.UserId then isWhitelisted = true; break end
        end
        if not isWhitelisted then return end
    end

    if settings.Range.Enabled then
        local myChar   = LocalCharacter or Players.LocalPlayer.Character
        local theirChar = player.Character
        if not myChar or not theirChar then return end

        local myRoot    = myChar:FindFirstChild("HumanoidRootPart")
        local theirRoot = theirChar:FindFirstChild("HumanoidRootPart") or theirChar:FindFirstChild("Torso")
        if not myRoot or not theirRoot then return end
        LocalRoot = myRoot

        local heightRange = settings.Range.Height or 0
        local dx          = myRoot.Position.X - theirRoot.Position.X
        local dz          = myRoot.Position.Z - theirRoot.Position.Z
        local dy          = math.abs(myRoot.Position.Y - theirRoot.Position.Y)
        local distXZ      = math.sqrt(dx*dx + dz*dz)

        if distXZ > settings.Range.Studs then return end
        if heightRange > 0 and dy > heightRange then return end

        if not settings.Range.IgnoreWalls then
            local origin = myRoot.Position
            local target = theirRoot.Position
            local dir    = target - origin
            RangeRaycastFilter[1] = myChar
            RangeRaycastFilter[2] = theirChar
            RangeRaycastParams.FilterDescendantsInstances = RangeRaycastFilter
            local result = workspace:Raycast(origin, dir, RangeRaycastParams)
            if result and result.Instance then return end
        end
    end

    rateLimiter:setCooldown(tonumber(settings.CooldownSecondsPerUser) or 0)
    if not rateLimiter:allow(player.UserId) then return end

    local cleaned = normalizeOneLine(stripTrigger(settings, message))
    if cleaned == "" then return end

    local queueKey = player.UserId
    local maxQueue = tonumber(settings.MaxQueuePerUser) or 3
    if maxQueue < 1 then maxQueue = 1 end
    local queued   = enqueueChatItem(queueKey, {
        userId      = player.UserId,
        displayName = player.DisplayName,
        name        = player.Name,
        cleaned     = cleaned,
        player      = player,
    }, maxQueue)
    if queued then runChatQueue(queueKey) end
end

