-- Кнопка вкладки
local function makeTabBtn(tabDef, order)
    local btn = frame(sbScroll, T.BgPanel, 1)
    btn.Name        = tabDef.id
    btn.Size        = UDim2.new(1, 0, 0, 38)
    btn.Active      = true
    btn.LayoutOrder = order

    corner(btn, 8)

    -- Иконка
    local ico = label(btn, tabDef.icon, 14, T.Sans, T.TextMid)
    ico.Size     = UDim2.new(0, 28, 1, 0)
    ico.Position = UDim2.new(0, 4, 0, 0)
    ico.TextXAlignment = Enum.TextXAlignment.Center

    -- Текст
    local lbl = label(btn, tabDef.label, 13, T.Sans, T.TextMid)
    lbl.Size     = UDim2.new(1, -40, 1, 0)
    lbl.Position = UDim2.new(0, 36, 0, 0)

    -- Активная полоска слева
    local activeLine = frame(btn, T.Accent)
    activeLine.Size     = UDim2.new(0, 3, 0, 20)
    activeLine.Position = UDim2.new(0, 0, 0.5, -10)
    activeLine.BackgroundTransparency = 1
    corner(activeLine, 3)

    -- Hover
    btn.MouseEnter:Connect(function()
        if activeTab ~= tabDef.id then
            tw(btn, tw_fast, {BackgroundTransparency = 0.7, BackgroundColor3 = T.BgHover})
            tw(lbl, tw_fast, {TextColor3 = T.Text})
        end
    end)
    btn.MouseLeave:Connect(function()
        if activeTab ~= tabDef.id then
            tw(btn, tw_fast, {BackgroundTransparency = 1})
            tw(lbl, tw_fast, {TextColor3 = T.TextMid})
        end
    end)

    local function setActive(on, instant)
        if on then
            if instant then
                btn.BackgroundColor3 = T.BgCard
                btn.BackgroundTransparency = 0
                lbl.TextColor3 = T.Text
                ico.TextColor3 = T.Accent
                activeLine.BackgroundTransparency = 0
            else
                tw(btn, tw_fast, {BackgroundTransparency = 0, BackgroundColor3 = T.BgCard})
                tw(lbl, tw_fast, {TextColor3 = T.Text})
                tw(ico, tw_fast, {TextColor3 = T.Accent})
                tw(activeLine, tw_fast, {BackgroundTransparency = 0})
            end
        else
            if instant then
                btn.BackgroundTransparency = 1
                lbl.TextColor3 = T.TextMid
                ico.TextColor3 = T.TextMid
                activeLine.BackgroundTransparency = 1
            else
                tw(btn, tw_fast, {BackgroundTransparency = 1})
                tw(lbl, tw_fast, {TextColor3 = T.TextMid})
                tw(ico, tw_fast, {TextColor3 = T.TextMid})
                tw(activeLine, tw_fast, {BackgroundTransparency = 1})
            end
        end
    end

    tabButtons[tabDef.id] = {btn=btn, setActive=setActive}
    return btn, setActive
end

