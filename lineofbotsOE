                "\n[DO:stop]   — stop moving" ..
                "\nRULES:" ..
                "\n- Use DIFFERENT tags. Don't get stuck on wave and laugh." ..
                "\n- Neutral reply = [DO:point] or no tag" ..
                "\n- Happy reply = [DO:cheer] or [DO:laugh]" ..
                "\n- Agreement = [DO:agree], disagreement = [DO:disagree]" ..
                "\nEXAMPLES:" ..
                "\nnice!→[DO:cheer]  haha→[DO:laugh]  yes→[DO:agree]  no→[DO:disagree]" ..
                "\nidk→[DO:shrug]  sorry→[DO:sorry]  what?→[DO:confused]  sad→[DO:sad]" ..
                "\nhi→[DO:wave]  shy→[DO:shy]  tired→[DO:sit]  dance→[DO:dance]")
        end
    end

    -- 2. Personality
    local personalityId = settings.PersonalityId
    local custom        = settings.CustomSystemPrompt
    local hasCustom     = type(custom) == "string" and custom:gsub("%s+","") ~= ""

    if hasCustom then
        table.insert(parts, custom)
    elseif type(personalityId) == "string" and Personalities[personalityId] then
        local fullPersonality = tostring(Personalities[personalityId].system or "")
        if settings.TokenEconomy then
            local short = fullPersonality:match("^(.-)\n\n") or fullPersonality:sub(1,300)
            table.insert(parts, short)
        else
            table.insert(parts, fullPersonality)
        end
    else
        table.insert(parts, "You are a player in a Roblox game. Chat naturally and briefly.")
    end

    -- 3. Language
    table.insert(parts,
        "LANGUAGE: Messages start with [LANG:XX]. [LANG:RU]=reply in Russian. [LANG:EN]=reply in English. [LANG:OTHER]=match player's language. Never switch languages mid-conversation.")

    -- 4. Place context
    if settings.PlaceAwareness then
        local info    = _placeInfo or { name = "a Roblox game", placeId = 0, desc = "" }
        local placeStr = "You are inside Roblox game: \"" .. tostring(info.name) .. "\""
        if info.desc and info.desc ~= "" then
            placeStr = placeStr .. ". Game description: " .. info.desc:sub(1,150)
        end
        table.insert(parts, placeStr)
    end

    -- 5. Player awareness
    if settings.PlayerAwareness then
        if settings.TokenEconomy then
            table.insert(parts, "[NEARBY] = players near you. Only mention positions when directly relevant.")
        else
            table.insert(parts,
                "NEARBY PLAYERS: You receive a [NEARBY] block before each message showing who is around you.\n" ..
                "Only mention player positions when relevant.\n" ..
                "Never list all players in every reply. Never print [NEARBY] tags in your reply.")
        end
    end

    -- 6. Player name
    if settings.UsePlayerName then
        table.insert(parts,
            "PLAYER NAME: Messages may start with [NAME:X] — that is the player's name. Use it naturally. Never write [NAME:...] literally.")
    end

    -- 7. World events
    if settings.WorldReactions then
        table.insert(parts,
            "WORLD EVENTS: Messages starting with [SYSTEM: ...] are automatic game events (not from players). React briefly in 1 sentence, stay in character. Never print [SYSTEM: in your reply.")
    end

    -- 8. Web search
    if settings.WebSearch then
        if settings.TokenEconomy then
            table.insert(parts, "Year: 2026. Use provided search results as facts.")
        else
            table.insert(parts,
                "WEB SEARCH: You have access to real-time search (year 2026). When search results are provided, use them as ground truth. Give SHORT answers — 1-3 sentences max.")
        end
    elseif not settings.TokenEconomy then
        table.insert(parts,
            "Your training has a cutoff date. For current trends, memes, or news — say you don't have up-to-date info.")
    end

    -- 9. compound-beta token limit
    if model == "compound-beta" or model == "compound-beta-mini" then
        table.insert(parts, "CRITICAL: After web search give ONLY 1-3 sentences. Never paste article text.")
    end

    local result       = table.concat(parts, "\n\n")
    _sysPromptCache    = result
    _sysPromptCacheKey = cacheKey
    return result
end

