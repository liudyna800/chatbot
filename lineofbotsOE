    sidebar.BackgroundColor3      = THEME.Sidebar
    sidebar.BackgroundTransparency = THEME.SidebarTransparency or 0.20
    sidebar.BorderSizePixel       = 0
    sidebar.Parent                = window
    makeCorner(sidebar, 18)

    local sidebarDivider = Instance.new("Frame")
    sidebarDivider.BackgroundColor3      = THEME.Stroke
    sidebarDivider.BackgroundTransparency = THEME.StrokeTransparency
    sidebarDivider.BorderSizePixel       = 0
    sidebarDivider.Position = UDim2.new(1,-1,0.05,0)
    sidebarDivider.Size     = UDim2.new(0,1,0.9,0)
    sidebarDivider.Parent   = sidebar

    local _auroraClock = 0
    trackConn(RunService.Heartbeat:Connect(function(dt)
        if not windowStroke or not windowStroke.Parent then return end
        _auroraClock = _auroraClock + dt
        local palette = THEME.AuroraPalette or AURORA_COLORS
        local t = (_auroraClock * (THEME.AuroraSpeed or 0.35)) % #palette
        local idx = math.floor(t)+1; local nidx = (idx%#palette)+1; local f = t-math.floor(t)
        local a,b = palette[idx],palette[nidx]
        windowStroke.Color = Color3.new(a.R+(b.R-a.R)*f,a.G+(b.G-a.G)*f,a.B+(b.B-a.B)*f)
        windowStroke.Transparency = 0.35
    end))

    -- Sidebar header
    local sidebarLogoArea = Instance.new("Frame")
    sidebarLogoArea.Size = UDim2.new(1,0,0,62)
    sidebarLogoArea.BackgroundTransparency = 1
    sidebarLogoArea.Parent = sidebar

    local logoAccent = Instance.new("Frame")
    logoAccent.Size = UDim2.new(0,4,0,28)
    logoAccent.AnchorPoint = Vector2.new(0,0.5)
    logoAccent.Position = UDim2.new(0,12,0.5,0)
    logoAccent.BackgroundColor3 = THEME.Accent
    logoAccent.BorderSizePixel = 0
    logoAccent.Parent = sidebarLogoArea
    makeCorner(logoAccent, 2)

    local _logoClock = 0
