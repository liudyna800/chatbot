-- v17: PLAYER AWARENESS SYSTEM
-- ИИ видит: кто рядом, с какой стороны, двигается ли/стоит/ведёт себя странно
-- ═══════════════════════════════════════════════════════════════════════════

-- Направление от нас к игроку относительно нашего взгляда
-- Возвращает: "перед", "сзади", "слева", "справа"
-- Направление от нас к игроку — 8 направлений, НА АНГЛИЙСКОМ
-- (ИИ англоязычный — кириллица в [NEARBY] игнорируется моделью)
local function getRelativeDirection(myRoot, theirRoot)
    if not myRoot or not theirRoot then return "nearby" end
    local diff = (theirRoot.Position - myRoot.Position)
    if diff.Magnitude < 0.1 then return "nearby" end
    local unit  = diff.Unit
    local look  = myRoot.CFrame.LookVector
    local right = myRoot.CFrame.RightVector

    local fwd = unit:Dot(look)
    local lat = unit:Dot(right)

    local DIAG = 0.42
    if     fwd > DIAG  and lat > DIAG  then return "front-right"
    elseif fwd > DIAG  and lat < -DIAG then return "front-left"
    elseif fwd < -DIAG and lat > DIAG  then return "behind-right"
    elseif fwd < -DIAG and lat < -DIAG then return "behind-left"
    elseif fwd > 0.3   then return "in front"
    elseif fwd < -0.3  then return "behind"
    elseif lat > 0     then return "to your right"
    else                    return "to your left"
    end
end

-- Оцениваем поведение игрока
local _playerBehaviorHistory = {}
local BEHAVIOR_HISTORY_LEN = 20  -- ~6 сек при тике 0.3с
local _behaviorThread = nil

-- Флаги активных токсиков: [userId] = true если обнаружен токсик
-- При следующем chat-запросе будет вставлен алерт
local _toxicAlerts = {}

local function startBehaviorMonitor()
    if _behaviorThread then return end
    _behaviorThread = task.spawn(function()
        while true do
            local myRoot = getLocalRootPart()
            if myRoot then
                local myPos  = myRoot.Position
                local myLook = myRoot.CFrame.LookVector

                for _, p in ipairs(Players:GetPlayers()) do
                    if p ~= Players.LocalPlayer then
                        local char = p.Character
                        local root = char and char:FindFirstChild("HumanoidRootPart")
                        if root then
                            local uid = p.UserId
                            if not _playerBehaviorHistory[uid] then
                                _playerBehaviorHistory[uid] = { entries = {} }
                            end
                            local hist = _playerBehaviorHistory[uid]

                            local diff = root.Position - myPos
                            local isBehind = false
                            if diff.Magnitude > 0.1 then
                                isBehind = diff.Unit:Dot(myLook) < 0
                            end

                            table.insert(hist.entries, {
                                pos      = root.Position,
                                time     = os.clock(),
                                isBehind = isBehind,
                                dir      = getRelativeDirection(myRoot, root),
                            })
                            if #hist.entries > BEHAVIOR_HISTORY_LEN then
                                table.remove(hist.entries, 1)
                            end
                        end
                    end
                end
            end
            task.wait(0.3)
        end
    end)
end

local function detectBehavior(uid, myRoot)
    local hist = _playerBehaviorHistory[uid]
    if not hist or #hist.entries < 4 then return "стоит" end

    local entries = hist.entries
    local n = #entries
    local totalDist  = 0
    local dirChanges = 0
    local behindCount = 0

    for i = 2, n do
        totalDist = totalDist + (entries[i].pos - entries[i-1].pos).Magnitude
        if entries[i].isBehind then behindCount = behindCount + 1 end
        if i >= 3 then
            local v1 = entries[i-1].pos - entries[i-2].pos
            local v2 = entries[i].pos   - entries[i-1].pos
            if v1.Magnitude > 0.05 and v2.Magnitude > 0.05 then
                if v1.Unit:Dot(v2.Unit) < -0.2 then  -- снижен порог
                    dirChanges = dirChanges + 1
                end
            end
        end
    end

    local dt = entries[n].time - entries[1].time
    local avgSpeed = dt > 0 and (totalDist / dt) or 0

    -- Снижены пороги: 30% тиков сзади + 1 смена + любое движение
    local behindRatio = behindCount / math.max(n - 1, 1)
    if behindRatio >= 0.30 and dirChanges >= 1 and avgSpeed > 0.15 then
        return "токсичит_сзади"
    elseif avgSpeed < 0.15 then
        return "стоит"
    else
        local myPos2 = myRoot and myRoot.Position or Vector3.zero
        local d1 = (entries[1].pos - myPos2).Magnitude
        local d2 = (entries[n].pos - myPos2).Magnitude
        if d2 < d1 - 2 then return "приближается"
        elseif d2 > d1 + 2 then return "удаляется"
        else return "ходит" end
    end
end

local function buildPlayerAwarenessContext(settings)
    if not settings.PlayerAwareness then return "" end
    local myRoot = getLocalRootPart()
    if not myRoot then return "" end

    local maxDist = (settings.Range.Enabled and settings.Range.Studs) or 20
    local lines = {}

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= Players.LocalPlayer then
            local char = p.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if root then
                local dist = (root.Position - myRoot.Position).Magnitude
                if dist <= maxDist then
                    local direction = getRelativeDirection(myRoot, root)
                    local behavior  = detectBehavior(p.UserId, myRoot)
                    local distStr   = math.floor(dist) .. " studs"
                    local name      = p.DisplayName or p.Name

                    -- Токсик обнаружен — ставим флаг для проактивного алерта
                    if behavior == "токсичит_сзади" then
                        _toxicAlerts[p.UserId] = name
                    end

                    local behaviorDesc = behavior == "стоит"            and "standing still"
                        or behavior == "приближается"  and "walking towards you"
                        or behavior == "удаляется"     and "walking away"
                        or behavior == "ходит"         and "moving around"
                        or behavior == "токсичит_сзади" and "TOXIC: back-and-forth movement behind you"
                        or "nearby"

                    table.insert(lines, string.format(
                        "  %s — %s (%s away), %s",
                        name, direction, distStr, behaviorDesc
                    ))
                end
            end
        end
    end

    -- Если рядом никого — возвращаем пустую строку (не тратим токены на "nobody around")
    if #lines == 0 then return "" end
    return "\n[NEARBY:\n" .. table.concat(lines, "\n") .. "\n]"
end

