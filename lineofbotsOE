local function handleQueuedChat(item)
    local settings = ClientSettings
    if not settings.Enabled then return end
    if not item.isWorld and not settings.AutoReply then return end
    if not item.cleaned or item.cleaned:match("^%s*$") then return end
    if not item.isWorld and item.player and not item.player.Parent then return end

    local history    = getHistory(settings, item.userId)
    local apiMessages = {}
    table.insert(apiMessages, { role = "system", content = makeSystemPrompt(settings) })

    if history then
        local maxPairs = math.max(1, math.min(50, tonumber(settings.MaxHistory) or MAX_HISTORY))
        local maxItems = maxPairs * 2
        local startIdx = math.max(1, #history - maxItems + 1)
        for i = startIdx, #history do table.insert(apiMessages, history[i]) end
    end

    local userContent = item.cleaned
    if settings.UsePlayerName then
        local shortName = extractShortName(item.name or "")
        if not shortName then shortName = extractShortName(item.displayName or "") end
        if not shortName then
            local fallback = item.name or item.displayName or ""
            if #fallback >= 2 then shortName = fallback:sub(1, 14) end
        end
        if shortName then userContent = "[NAME:" .. shortName .. "] " .. item.cleaned end
    end

    if settings.PlayerAwareness then
        local nearbyCtx = buildPlayerAwarenessContext(settings)
        if nearbyCtx ~= "" then
            table.insert(apiMessages, { role = "system", content = "CURRENT SURROUNDINGS (live snapshot):" .. nearbyCtx })
        end
        local toxicNames = {}
        for uid, tname in pairs(_toxicAlerts) do
            table.insert(toxicNames, tostring(tname))
            _toxicAlerts[uid] = nil
        end
        if #toxicNames > 0 then
            table.insert(apiMessages, {
                role    = "system",
                content = "⚠ TOXIC BEHAVIOR DETECTED: player(s) [" .. table.concat(toxicNames, ", ")
                    .. "] were repeatedly moving back-and-forth behind you. React naturally — call them out, say you noticed, or warn them."
            })
        end
    end

    if settings.WebSearch and item.cleaned and #item.cleaned > 3 then
        local searchResult, searchDone = nil, false
        task.spawn(function()
            local ok, res = pcall(doWebSearch, item.cleaned)
            searchResult = ok and res or nil
            searchDone   = true
        end)
        local swMax, swCount = 40, 0
        while not searchDone and swCount < swMax do task.wait(0.2); swCount = swCount + 1 end
        local sr = searchResult or ""
        if sr ~= "" and not sr:find("не найдены") and not sr:find("Ошибка") then
            table.insert(apiMessages, {
                role    = "system",
                content = "[WEB SEARCH RESULTS for: " .. item.cleaned .. "]\n" .. sr ..
                    "\n[INSTRUCTION: This is live data from 2026. Use these results as your PRIMARY source. Answer confidently. Do NOT say you lack current info.]"
            })
        end
    end

    local langTag = item.isWorld and "RU" or getLangForUser(item.cleaned, item.userId)
    table.insert(apiMessages, { role = "user", content = "[LANG:" .. langTag .. "] " .. userContent })

    local model = getModel(settings)
    model = (model and model:match("^%s*(.-)%s*$")) or ""
    if model == "" then
        if ClientSettings.Debug then print("[LOB] no model selected") end
        return
    end

    local maxTok = tonumber(settings.MaxTokens) or 512
    if settings.TokenEconomy then
        local minTok = (model:find("maverick") or model:find("scout")) and 256 or 150
        maxTok = math.min(maxTok, minTok)
    end

    local payload = {
        model       = model,
        temperature = tonumber(settings.Temperature) or 0.7,
        max_tokens  = maxTok,
        messages    = apiMessages,
    }

    if model == "qwen/qwen3-32b" then
        payload.reasoning_effort = "none"
        payload.temperature      = nil
    end

    local skipTools = model:find("^gemini") or model:find("compound%-beta")
        or model == "qwen/qwen3-32b"
        or model:find("kimi") or model:find("moonshotai")

    if settings.WebSearch and not skipTools then
        payload.tools = {{
            type = "function",
            ["function"] = {
                name        = "web_search",
                description = "Поиск актуальной информации в интернете: новости, мемы, события, факты.",
                parameters  = {
                    type       = "object",
                    properties = {
                        query = { type = "string", description = "Поисковый запрос на русском или английском" }
                    },
                    required = {"query"}
                }
            }
        }}
    end

    local isGemini3x = model:find("^gemini%-3")
    local isGemini   = model:find("^gemini")
    local isKimi     = model:find("kimi") or model:find("moonshotai")
    local timeoutSec = isGemini3x and 20 or (isGemini and 20 or (isKimi and 15 or 8))

    local text, err
    do
        local done = false
        task.spawn(function() text, err = providerRouter:chatCompletions(payload); done = true end)
        local waited = 0
        while not done and waited < timeoutSec do task.wait(0.5); waited = waited + 0.5 end
        if not done then
            local q2 = ChatQueue[item.userId or 0]
            if q2 then q2.startedAt = 0 end
            if ClientSettings.Debug then print("[LOB] timeout after " .. timeoutSec .. "s for model: " .. model) end
            return
        end
    end

    if (not text or text == "") and err and tostring(err):find("429") then
        if ClientSettings.Debug then print("[LOB] 429 rate limit, skipping retry") end
    end
    if err or not text or text == "" then
        if ClientSettings.Debug then print("[LOB] AI error: " .. tostring(err or "empty response")) end
        return
    end

    text = text:match("^%s*(.-)%s*$") or text
    text = text:gsub("%[NAME:[^%]]*%]%s*", "")
    text = text:gsub("[\n]?%[Sources?%][%s%S]*$", "")
    text = text:gsub("[\n]?Sources?:%s*%d+%.[%s%S]*$", "")
    text = text:gsub("<think>.-</think>%s*", "")
    text = text:gsub("^%*%*[^%*]+%*%*:?%s*", "")
    text = text:match("^%s*(.-)%s*$") or text

    if settings.CameraLook and item.player and item.player.Character then
        local pRoot = item.player.Character:FindFirstChild("HumanoidRootPart")
        if pRoot then smoothLookAt(pRoot.Position) end
    end

    local actionName, cleanText = parseActionTag(text)
    if not item.isWorld or settings.AutoReply then
        cleanText = executeAction(actionName, item.player, cleanText, item.cleaned)
    else
        cleanText = cleanText or text
    end

    if history then
        local historyUserMsg = item.cleaned
        if settings.UsePlayerName and userContent ~= item.cleaned then
            historyUserMsg = userContent:gsub("%[LANG:[^%]]*%]%s*", "")
        end
        historyUserMsg = historyUserMsg:gsub("%[LANG:[^%]]*%]%s*", "")
        historyUserMsg = historyUserMsg:gsub("%[NAME:[^%]]*%]%s*", "")
        appendHistory(history, historyUserMsg, cleanText)
    end

    if cleanText and cleanText ~= "" then sendBotMessage(cleanText) end
end

-- §RUN_QUEUE
local function runChatQueue(userId)
    local q = getChatQueue(userId)
    if q.running then return end
    if q.head > q.tail then return end
    q.running   = true
    q.startedAt = os.clock()
    task.spawn(function()
        local ran_ok, ran_err = pcall(function()
            while true do
                local item = dequeueChatItem(q)
                if not item then break end
                q.startedAt = os.clock()
                local ok, err2 = pcall(handleQueuedChat, item)
                if not ok then print("[LOB] handleQueuedChat error: " .. tostring(err2)) end
                if q.head <= q.tail then task.wait(0.05) end
            end
        end)
        q.running   = false
        q.startedAt = 0
        if not ran_ok then print("[LOB] runChatQueue panic: " .. tostring(ran_err)) end
    end)
end

