    return count * 6000
end

local function isSlotAvailable(slot)
    local keys = getGroqKeys()
    if keys[slot] == "" then return false end
    return (os.clock() - _groqCooldownAt[slot]) >= GROQ_COOLDOWN
end

local function getGroqApiKey()
    if isSlotAvailable(_groqActiveSlot) then
        return getGroqKeys()[_groqActiveSlot]
    end
    for i = 1, 3 do
        local slot = (_groqActiveSlot % 3) + 1
        _groqActiveSlot = slot
        if isSlotAvailable(slot) then
            return getGroqKeys()[slot]
        end
    end
    local bestSlot = 1
    local bestTime = _groqCooldownAt[1]
    local keys = getGroqKeys()
    for i = 2, 3 do
        if keys[i] ~= "" and _groqCooldownAt[i] < bestTime then
            bestTime = _groqCooldownAt[i]
            bestSlot = i
        end
    end
    _groqActiveSlot = bestSlot
    return keys[bestSlot]
end

local function switchGroqSlot()
    _groqCooldownAt[_groqActiveSlot] = os.clock()
    if ClientSettings.Debug then
        print("[LOB] Groq slot " .. _groqActiveSlot .. " rate limited, rotating...")
    end
    for i = 1, 3 do
        local next = (_groqActiveSlot % 3) + 1
        _groqActiveSlot = next
        if isSlotAvailable(next) then
            if ClientSettings.Debug then print("[LOB] Groq switched to slot " .. next) end
            return
        end
    end
    _groqActiveSlot = (_groqActiveSlot % 3) + 1
end

local function isRateLimited(statusCode, statusMsg, body)
    local sc = tonumber(statusCode) or 0
    if sc == 429 or sc == 503 then return true end
    local msg = tostring(statusMsg or ""):lower()
    local b   = tostring(body or ""):lower()
    if msg:find("rate") or b:find("rate") or b:find("too many") or b:find("overload") then
        return true
    end
    return false
end

-- §WEBSEARCH
local function doWebSearch(query)
    local httprequest = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request
    if not httprequest then return "Поиск недоступен." end

    local function urlEncode(s)
        return s:gsub(" ", "+"):gsub("[^%w%+%-_%.~]", function(c)
            return string.format("%%%02X", string.byte(c))
        end)
    end
    local function urlEncodePath(s)
        return s:gsub("[^%w%-_%.~]", function(c)
            return string.format("%%%02X", string.byte(c))
        end)
    end
    local function stripTags(s)
        s = s:gsub("<[^>]+>", "")
        s = s:gsub("&amp;", "&"):gsub("&lt;", "<"):gsub("&gt;", ">")
              :gsub("&quot;", '"'):gsub("&#39;", "'"):gsub("&nbsp;", " ")
        return (s:match("^%s*(.-)%s*$") or s)
    end

    local results = {}

    -- 1. Wikipedia Summary API
    local wikiTerm = (query:match("^([%w%s%-]+)") or query):match("^%s*(.-)%s*$") or query
    local ok1, res1 = pcall(httprequest, {
        Url     = "https://en.wikipedia.org/api/rest_v1/page/summary/" .. urlEncodePath(wikiTerm),
        Method  = "GET",
        Headers = { ["Accept"] = "application/json" },
    })
    if ok1 and res1 then
        local body1 = res1.Body or res1.body or ""
        local ok_dec, data1 = pcall(function() return HttpService:JSONDecode(body1) end)
        if ok_dec and data1 and type(data1.extract) == "string" and data1.extract ~= ""
           and data1.type ~= "disambiguation" then
            table.insert(results, "[Wiki] " .. data1.extract:sub(1, 500))
        end
    end

    -- 2. Google News RSS
    local ok2, res2 = pcall(httprequest, {
        Url     = "https://news.google.com/rss/search?q=" .. urlEncode(query) .. "&hl=en-US&gl=US&ceid=US:en",
        Method  = "GET",
        Headers = { ["Accept"] = "application/rss+xml, text/xml" },
    })
    if ok2 and res2 then
        local body2 = res2.Body or res2.body or ""
        local newsCount = 0
        for item in body2:gmatch("<item>(.-)</item>") do
            if newsCount >= 3 then break end
            local rawTitle = item:match("<title><!%[CDATA%[(.-)%]%]></title>")
                          or item:match("<title>([^<]+)</title>") or ""
            local rawDate  = item:match("<pubDate>([^<]+)</pubDate>") or ""
            local t = stripTags(rawTitle):sub(1, 160)
            local d = rawDate:match("^(.-%d%d%d%d)") or rawDate:sub(1, 30)
            if t ~= "" and not t:find("^Google News") then
                local entry = (d ~= "") and ("[News " .. d .. "] " .. t) or ("[News] " .. t)
                table.insert(results, entry)
                newsCount = newsCount + 1
            end
        end
    end

    -- 3. Jina Reader fallback
    if #results < 2 then
        local jinaUrl = "https://r.jina.ai/https://en.wikipedia.org/wiki/" .. urlEncodePath(wikiTerm)
        local ok3, res3 = pcall(httprequest, {
            Url     = jinaUrl,
            Method  = "GET",
            Headers = { ["Accept"] = "text/plain" },
        })
        if ok3 and res3 then
            local body3 = res3.Body or res3.body or ""
            local text = body3:gsub("\n+", " "):gsub("%s+", " "):match("^%s*(.-)%s*$") or ""
            if #text > 80 then
                table.insert(results, "[Jina] " .. text:sub(1, 500))
            end
        end
    end

    if #results == 0 then return "Результаты не найдены для: " .. query end
    return table.concat(results, "\n")
end

local GroqRateLimitCache = {
    remainingRequests = nil,
    limitRequests     = nil,
    resetRequests     = nil,
    remainingTokens   = nil,
    limitTokens       = nil,
    updatedAt         = nil,
}
local onRateLimitUpdate = nil

local function parseRateLimitHeaders(hdrs)
    if type(hdrs) ~= "table" then return end
    local function get(name)
        local lo = name:lower()
        if hdrs[name] then return tostring(hdrs[name]) end
        for k, v in pairs(hdrs) do
            if tostring(k):lower() == lo then return tostring(v) end
        end
    end
    local rr = get("x-ratelimit-remaining-requests")
    local lr = get("x-ratelimit-limit-requests")
    local rs = get("x-ratelimit-reset-requests")
    local rt = get("x-ratelimit-remaining-tokens")
    local lt = get("x-ratelimit-limit-tokens")
    if rr or rt then
        GroqRateLimitCache.remainingRequests = rr
        GroqRateLimitCache.limitRequests     = lr
        GroqRateLimitCache.resetRequests     = rs
        GroqRateLimitCache.remainingTokens   = rt
        GroqRateLimitCache.limitTokens       = lt
        GroqRateLimitCache.updatedAt         = os.clock()
        if onRateLimitUpdate then task.spawn(onRateLimitUpdate) end
    end
end

function GroqProvider:chatCompletions(payload)
    local apiKey = getGroqApiKey()
    if type(apiKey) ~= "string" or apiKey == "" then
        return nil, "MissingGroqKey"
    end

    local url = "https://api.groq.com/openai/v1/chat/completions"
    local res, statusCode, statusMsg, body, respHeaders = postJson(url, {
        ["Content-Type"]  = "application/json",
        ["Authorization"] = "Bearer " .. apiKey,
    }, payload)

    if respHeaders then parseRateLimitHeaders(respHeaders) end

    if not res then
        if isRateLimited(statusCode, statusMsg, body) then
            switchGroqSlot()
            local newKey = getGroqApiKey()
            if newKey and newKey ~= "" and newKey ~= apiKey then
                local res2, sc2, sm2, b2, rh2 = postJson(url, {
                    ["Content-Type"]  = "application/json",
                    ["Authorization"] = "Bearer " .. newKey,
                }, payload)
                if rh2 then parseRateLimitHeaders(rh2) end
                if res2 then
                    local choice2 = res2.choices and res2.choices[1]
                    if choice2 then
                        local msg2 = choice2.message
                        if msg2 and type(msg2.content) == "string" and msg2.content ~= "" then
                            return msg2.content, nil
                        end
                    end
                end
            end
            if onApiRateLimited then onApiRateLimited("groq") end
        end
        return nil, tostring(statusCode or "") .. ":" .. tostring(statusMsg or "") .. ":" .. tostring(body or "")
    end

    local choice = res.choices and res.choices[1]
    if not choice then return nil, "NoChoicesReturned" end
    if choice.finish_reason == "content_filter" then return nil, "ContentFiltered" end

    -- Tool use (web search via function calling)
    if choice.finish_reason == "tool_calls" and choice.message and choice.message.tool_calls then
        local toolResults = {}
        for _, tc in ipairs(choice.message.tool_calls) do
            local fn = tc["function"]
            if fn and fn.name == "web_search" then
                local args = {}
                pcall(function() args = HttpService:JSONDecode(fn.arguments or "{}") end)
                local query = args.query or ""
                local searchResult = doWebSearch(query)
                table.insert(toolResults, {
                    role        = "tool",
                    tool_call_id = tc.id,
                    content     = searchResult,
                })
            end
        end
        if #toolResults > 0 then
            local msgs2 = {}
            for _, m in ipairs(payload.messages) do table.insert(msgs2, m) end
            table.insert(msgs2, choice.message)
            for _, tr in ipairs(toolResults) do table.insert(msgs2, tr) end
            local payload2 = {
                model       = payload.model,
                temperature = payload.temperature,
                max_tokens  = payload.max_tokens,
                messages    = msgs2,
            }
            local res2, sc2, sm2, b2, rh2 = postJson(url, {
                ["Content-Type"]  = "application/json",
                ["Authorization"] = "Bearer " .. apiKey,
            }, payload2)
            if rh2 then parseRateLimitHeaders(rh2) end
            if res2 then
                local c2   = res2.choices and res2.choices[1]
                local msg2 = c2 and c2.message
                local content2 = msg2 and msg2.content
                if type(content2) == "string" and content2 ~= "" then
                    return content2, nil
                end
            end
        end
    end

    local msg     = choice.message
    local content = msg and msg.content

    -- compound-beta returns content as array of blocks
    if type(content) == "table" then
        local parts = {}
        for _, block in ipairs(content) do
            if type(block) == "table" and block.type == "text" and type(block.text) == "string" and block.text ~= "" then
                table.insert(parts, block.text)
            end
        end
        content = table.concat(parts, " ")
    end

    if type(content) ~= "string" or content == "" then return nil, "EmptyResponse" end
    return content, nil
end

-- §GEMINI
local GeminiProvider = {}
GeminiProvider.__index = GeminiProvider

function GeminiProvider.new()
    return setmetatable({}, GeminiProvider)
end

function GeminiProvider:chatCompletions(payload)
    local apiKey = ClientSettings.ApiKeys and ClientSettings.ApiKeys.gemini
    apiKey = type(apiKey) == "string" and apiKey:gsub("%s+","") or ""
    if apiKey == "" then return nil, "MissingGeminiKey" end

    local model = payload.model or "gemini-2.5-flash"
    local url = "https://generativelanguage.googleapis.com/v1beta/models/"
        .. model .. ":generateContent?key=" .. apiKey

    local systemParts  = {}
    local contents     = {}
    local lastLangCode = nil
    local lastPlayerName = nil

    -- Find lang/name tags from last user message
    for j = #(payload.messages or {}), 1, -1 do
        local m = payload.messages[j]
        if m.role == "user" then
            local t = tostring(m.content or "")
            lastLangCode   = t:match("%[LANG:([A-Z]+)%]")
            lastPlayerName = t:match("%[NAME:([^%]]+)%]")
            break
        end
    end

    -- Build contents
    for _, m in ipairs(payload.messages or {}) do
        if m.role == "system" then
            table.insert(systemParts, tostring(m.content or ""))
        elseif m.role == "user" then
            local userText = tostring(m.content or "")
            userText = userText:gsub("%[LANG:[A-Z]+%]%s*", "")
            userText = userText:gsub("%[NAME:[^%]]+%]%s*", "")
            if userText:match("^%[SYSTEM:") then
                userText = userText:gsub("^%[SYSTEM:%s*", ""):gsub("%]%s*$", "")
            end
            userText = userText:match("^%s*(.-)%s*$") or userText
            if userText == "" then userText = "..." end
            table.insert(contents, { role = "user", parts = {{ text = userText }} })
        elseif m.role == "assistant" then
            local aText = tostring(m.content or "")
            aText = aText:gsub("%[DO:[^%]]*%]%s*", "")
            aText = aText:gsub("<think>.-</think>%s*", "")
            aText = aText:gsub("^%*%*[^%*]+%*%*:?%s*", "")
            aText = aText:match("^%s*(.-)%s*$") or aText
            if aText == "" then aText = "..." end
            table.insert(contents, { role = "model", parts = {{ text = aText }} })
        end
    end

    if lastPlayerName or lastLangCode then
        local ctx = ""
        if lastPlayerName then ctx = ctx .. "The player's name is " .. lastPlayerName .. ". " end
        if lastLangCode == "RU" then
            ctx = ctx .. "IMPORTANT: Reply in Russian only."
        elseif lastLangCode == "EN" then
            ctx = ctx .. "IMPORTANT: Reply in English only."
        end
        if ctx ~= "" then table.insert(systemParts, ctx) end
    end

    -- Enforce strict user/model alternation
    if #contents == 0 then
        table.insert(contents, { role = "user", parts = {{ text = "(start)" }} })
    end
    if contents[1].role == "model" then
        table.insert(contents, 1, { role = "user", parts = {{ text = "(start)" }} })
    end
    local i = 1
    while i < #contents do
        if contents[i].role == contents[i+1].role then
            local fillRole = (contents[i].role == "user") and "model" or "user"
            table.insert(contents, i+1, { role = fillRole, parts = {{ text = "..." }} })
        end
        i = i + 1
    end
    if #contents > 0 and contents[#contents].role ~= "user" then
        table.insert(contents, { role = "user", parts = {{ text = "(continue)" }} })
    end

    local isGemini3x = model:find("^gemini%-3") ~= nil
    local geminiTemp = isGemini3x and 1.0 or math.max(0.5, math.min(2.0, payload.temperature or 0.7))
    local genConfig  = {
        maxOutputTokens = payload.max_tokens or 300,
        temperature     = geminiTemp,
    }
    if isGemini3x then
        genConfig.thinkingConfig = { thinkingBudget = 0 }
    end

    local body = {
        contents         = contents,
        generationConfig = genConfig,
        safetySettings   = {
            { category = "HARM_CATEGORY_HARASSMENT",        threshold = "BLOCK_NONE" },
            { category = "HARM_CATEGORY_HATE_SPEECH",       threshold = "BLOCK_NONE" },
            { category = "HARM_CATEGORY_SEXUALLY_EXPLICIT", threshold = "BLOCK_NONE" },
            { category = "HARM_CATEGORY_DANGEROUS_CONTENT", threshold = "BLOCK_NONE" },
        },
    }
    if #systemParts > 0 then
        body.systemInstruction = { parts = {{ text = table.concat(systemParts, "\n\n") }} }
    else
        body.systemInstruction = { parts = {{ text = "You are a helpful assistant in a Roblox game. Reply briefly and naturally." }} }
    end

    local res, statusCode, statusMsg, rawBody, respHeaders = postJson(url, {
        ["Content-Type"] = "application/json",
    }, body)

    if not res then
        if isRateLimited(statusCode, statusMsg, rawBody) and onApiRateLimited then
            onApiRateLimited("gemini")
        end
        local errMsg = tostring(statusCode or "") .. ":" .. tostring(statusMsg or "")
        pcall(function()
            local b = HttpService:JSONDecode(tostring(rawBody or "{}"))
            if b.error and b.error.message then
                errMsg = errMsg .. ":" .. tostring(b.error.message):sub(1, 120)
            end
        end)
        return nil, errMsg
    end

    local cands = res.candidates
    if not cands or not cands[1] then
        if res.promptFeedback and res.promptFeedback.blockReason then
            return nil, "GeminiBlocked:" .. tostring(res.promptFeedback.blockReason)
        end
        return nil, "NoGeminiCandidates"
    end
    local cand = cands[1]
    if cand.finishReason == "SAFETY" or cand.finishReason == "RECITATION" then
        return nil, "GeminiFiltered:" .. tostring(cand.finishReason)
    end
    if cand.finishReason == "OTHER" or cand.finishReason == "BLOCKLIST" then
        if ClientSettings.Debug then print("[LOB] Gemini finishReason: " .. tostring(cand.finishReason)) end
    end
    local parts = cand.content and cand.content.parts
    if not parts or #parts == 0 then return nil, "NoGeminiParts" end

    local textParts = {}
    for _, part in ipairs(parts) do
        if type(part.text) == "string" and part.text ~= "" and not part.thought then
            table.insert(textParts, part.text)
        end
    end
    local finalText = table.concat(textParts, " ")
    if finalText == "" then return nil, "GeminiEmptyText" end
    return finalText, nil
end

