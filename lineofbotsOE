local function BuildSystem(nearby, avatarNote)
    local parts = {Cfg.SystemPrompt}
    table.insert(parts, "\n--- КОНТЕКСТ ---")
    table.insert(parts, "Игра: " .. RealGameName .. " (PlaceId: " .. tostring(game.PlaceId) .. ")")
    table.insert(parts, "Твой ник: " .. LP.Name .. (LP.DisplayName ~= LP.Name and " (display: " .. LP.DisplayName .. ")" or ""))
    table.insert(parts, "Имя бота: " .. Cfg.BotName)

    if #nearby > 0 then
        local ns = {}
        for _, p in ipairs(nearby) do
            table.insert(ns, string.format("%s (@%s) — %d м", p.displayName, p.name, p.distance))
        end
        table.insert(parts, "Рядом: " .. table.concat(ns, ", "))
    else
        table.insert(parts, "Никого рядом нет.")
    end

    if avatarNote then
        table.insert(parts, "Внешность собеседника: " .. avatarNote)
    end

    table.insert(parts, "--- КОНЕЦ КОНТЕКСТА ---")
    table.insert(parts, "Отвечай ТОЛЬКО текстом сообщения. Без рассуждений.")
    return table.concat(parts, "\n")
end

local function BuildMessages(userLine, senderName, nearby, avatarNote)
    local sys = BuildSystem(nearby, avatarNote)
    local msgs = {{role = "system", content = sys}}
    for _, h in ipairs(History) do
        table.insert(msgs, h)
    end
    table.insert(msgs, {role = "user", content = string.format("[%s]: %s", senderName, userLine)})
    return msgs
end

