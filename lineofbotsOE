local _worldReactCooldowns = {}
local WORLD_REACT_COOLDOWN = 60
local WORLD_REACT_STARE_CD = 45

local _worldReactCleanAt = 0
local function _canWorldReact(userId, reactType)
    local key = tostring(userId) .. (reactType or "")
    local now = os.clock()
    local t   = _worldReactCooldowns[key]
    local cd  = (reactType == "stare") and WORLD_REACT_STARE_CD or WORLD_REACT_COOLDOWN
    if t and (now - t) < cd then return false end
    _worldReactCooldowns[key] = now
    if (now - _worldReactCleanAt) > 120 then
        _worldReactCleanAt = now
        for k, ts in pairs(_worldReactCooldowns) do
            if (now - ts) > WORLD_REACT_COOLDOWN * 2 then _worldReactCooldowns[k] = nil end
        end
    end
    return true
end

-- §LANG
local _userLangCache = {}

local function detectLang(text)
    if not text or text == "" then return nil end
    local t   = text:lower()
    local cyr = 0
    for _ in t:gmatch("[\xd0-\xd1][\x80-\xbf]") do cyr = cyr + 1 end
    local lat = 0
    for w in t:gmatch("[a-z]+") do if #w > 2 then lat = lat + 1 end end
    if cyr > 1 then return "RU" end
    if lat > 0 then return "EN" end
    return nil
end

local function getLangForUser(text, userId)
    local lang = detectLang(text)
    if lang then
        if userId then _userLangCache[userId] = lang end
        return lang
    end
    if userId and _userLangCache[userId] then return _userLangCache[userId] end
    return "EN"
end

