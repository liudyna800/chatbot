    local hasTouch     = uis.TouchEnabled
    local hasKeyboard  = uis.KeyboardEnabled
    local isMobile     = hasTouch and not hasKeyboard

    if not isMobile then
        local presets = {
            {w=650,h=450},{w=700,h=460},{w=900,h=600},{w=1050,h=720},
        }
        local ok = false
        for _, p in ipairs(presets) do if winW==p.w and winH==p.h then ok=true break end end
        if not ok then
            winW=700; winH=460
            ClientSettings.UI = ClientSettings.UI or {}
