        ChatTestCallback=function(response,isErr)
            unblockSend(); pcall(function() typingBubble:Destroy() end); ctAddMessage(response,true,isErr); ChatTestCallback=nil
        end
        local settings=ClientSettings
        task.spawn(function()
            local apiMsgs={{role="system",content=makeSystemPrompt(settings)}}
            if settings.MemoryEnabled then for _,m in ipairs(DirectChatHistory) do table.insert(apiMsgs,m) end end
            local userContent=msg
            if settings.UsePlayerName then userContent="[NAME:User] "..msg end
            if settings.WebSearch and msg and #msg>3 then
                local sr,sd=nil,false
                task.spawn(function() local ok,res=pcall(doWebSearch,msg); sr=ok and res or nil; sd=true end)
                local sw,sc=40,0; while not sd and sc<sw do task.wait(0.2); sc=sc+1 end
                local s2=sr or ""; if s2~="" and not s2:find("не найдены") then
                    table.insert(apiMsgs,{role="system",content="[WEB SEARCH RESULTS for: "..msg.."]\n"..s2.."\n[INSTRUCTION: Use these as PRIMARY source.]"})
                end
            end
            table.insert(apiMsgs,{role="user",content="[LANG:"..getLangForUser(msg,nil).."] "..userContent})
            local directMaxTok=math.max(tonumber(settings.MaxTokens) or 512,512)
            local payload={model=getModel(settings),temperature=tonumber(settings.Temperature) or 0.7,max_tokens=directMaxTok,messages=apiMsgs}
            if payload.model=="qwen/qwen3-32b" then payload.reasoning_effort="none"; payload.temperature=nil end
            local text,err=providerRouter:chatCompletions(payload)
            if not text and err then
                local el=tostring(err):lower()
                if el:find("timeout") or el:find("network") or el:find("connection") then task.wait(2); text,err=providerRouter:chatCompletions(payload) end
            end
            if text and text~="" then
                text=text:gsub("<think>.-</think>%s*",""):gsub("^%*%*[^%*]+%*%*:?%s*",""):match("^%s*(.-)%s*$") or text
            end
            if text and text~="" and settings.MemoryEnabled then appendHistory(DirectChatHistory,userContent,text) end
            if ChatTestCallback then
                if err then
                    local el2=tostring(err):lower()
                    local fe
                    if el2:find("contentfiltered") or el2:find("emptyresponse") then fe="🚫 Модель отказалась отвечать."
                    elseif el2:find("429") or el2:find("rate") then fe="⚡ Rate limit — подожди немного."
                    elseif el2:find("401") or el2:find("missinggroqkey") then fe="🔑 API ключ неверный или не указан."
                    elseif el2:find("400") then fe="⚠️ Модель не поддерживает этот запрос."
                    elseif el2:find("timeout") or el2:find("timed") then fe="⏱️ Таймаут. Попробуй позже."
                    else fe="❌ Ошибка: "..tostring(err) end
                    ChatTestCallback(fe,true)
                else ChatTestCallback(text or "Нет ответа",false) end
            end
        end)
        task.delay(90,function() if ChatTestCallback then ChatTestCallback("⏱️ Нет ответа (90с).",true) end end)
    end
