    _guiScale = guiScale
    local scaledW = math.floor(winW * guiScale)
    local scaledH = math.floor(winH * guiScale)

    local windowHolder = Instance.new("Frame")
    windowHolder.BackgroundTransparency = 1
    windowHolder.BorderSizePixel = 0
    windowHolder.Size   = UDim2.new(0, scaledW, 0, scaledH)
    do
        local margin = 16
        local vp = viewportSize
        local x = math.clamp(math.floor((vp.X-scaledW)*0.5), margin, math.max(margin, vp.X-scaledW-margin))
        local y = math.clamp(math.floor((vp.Y-scaledH)*0.5+10), margin, math.max(margin, vp.Y-scaledH-margin))
        windowHolder.Position = UDim2.fromOffset(x, y)
    end
    windowHolder.Active = true
    windowHolder.Parent = gui
    local uiScale = Instance.new("UIScale")
    uiScale.Scale  = guiScale
    uiScale.Parent = windowHolder
