-- §SCREEN_SIZE  — определяем размер экрана
-- ══════════════════════════════════════════════════════
local function getScreenSize()
    local camera = workspace.CurrentCamera
    return camera and camera.ViewportSize or Vector2.new(1280, 720)
end

local function getDeviceLayout()
    local sz = getScreenSize()
    local w, h = sz.X, sz.Y
    local minDim = math.min(w, h)
    if minDim < 500 then
        return "phone",  math.min(w - 20, 400),  math.min(h - 60, 580)
    elseif minDim < 800 then
        return "tablet", math.min(w - 40, 640),  math.min(h - 80, 480)
    else
        return "desktop", 760, 500
    end
end

