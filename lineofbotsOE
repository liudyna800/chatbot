local active = false
local lastKickOpen = 0
local kickCooldown = 1.0

local function fastClick(obj)
    pcall(function()
        if firesignal then firesignal(obj.Activated); firesignal(obj.MouseButton1Click)
        else obj:Click() end
    end)
end

task.spawn(function()
    while true do
        if active then
            local target = InputField.Text:lower()
            if target == "" then
                StatusLabel.Text = "Ошибка: Введите ник!"
                task.wait(0.5)
            else
                local targetFound = false
                for _, obj in ipairs(game:GetDescendants()) do
                    if not active then break end
                    if obj:IsA("TextButton") or obj:IsA("ImageButton") then
                        local nameMatch = obj.Name:lower():find(target)
                        local textMatch = false
                        if obj:IsA("TextButton") then textMatch = obj.Text:lower():find(target) end
                        if nameMatch or textMatch then
                            fastClick(obj); StatusLabel.Text = "КЛИК ПО НИКУ!"
                            targetFound = true; task.wait(0.5); break
                        end
                    end
                end
                if not targetFound then
                    if tick() - lastKickOpen > kickCooldown then
                        for _, obj in ipairs(game:GetDescendants()) do
                            if obj.Name == "Kick" and obj:IsA("GuiButton") then
                                fastClick(obj); lastKickOpen = tick()
                                StatusLabel.Text = "Открываем меню..."; break
                            end
                        end
                    end
                end
            end
        else
            StatusLabel.Text = "Статус: Остановлен"
        end
        task.wait(0.1)
    end
end)

