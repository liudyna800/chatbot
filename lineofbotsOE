    CurrentGui        = gui
    NotifyHost        = nil
    ensureNotifyHost()

    local toggleInputConn
    toggleInputConn = game:GetService("UserInputService").InputBegan:Connect(function(input, gpe)
        if gpe then return end
        local key = ClientSettings.ToggleKey or Enum.KeyCode.P
        if input.KeyCode == key then gui.Enabled = not gui.Enabled end
    end)
    gui.Destroying:Connect(function() if toggleInputConn then toggleInputConn:Disconnect() end end)

    local guiScale = 1.0
    if isMobile then
        local scaleByW = (viewportSize.X * 0.88) / winW
        local scaleByH = (viewportSize.Y * 0.80) / winH
        guiScale = math.max(math.min(scaleByW, scaleByH, 1.0), 0.40)
