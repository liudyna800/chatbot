-- Utility functions
local function normalizeOneLine(s)
    s = tostring(s or "")
    s = s:gsub("\r", " "):gsub("\n", " ")
    s = s:gsub("%s+", " ")
    if ClientSettings.StripHash ~= false then
        s = s:gsub("#", "")
        s = s:gsub("%s+", " ")
    end
    s = s:match("^%s*(.-)%s*$")
    return s
end

local function extractShortName(nick)
    if type(nick) ~= "string" or nick == "" then return nil end
    local s = nick:gsub("[_%-]", " ")
    local best = nil
    for word in s:gmatch("[A-Za-z]+") do
        if #word >= 3 then
            if word:match("^[A-Z][a-z][a-z]") then
                if not best or #word > #best then best = word end
            elseif not best and #word >= 3 then
                best = word
            end
        end
    end
    if best then return best:sub(1, 14) end
    local prefix = nick:match("^([A-Za-z]+)")
    if prefix and #prefix >= 2 then return prefix:sub(1, 14) end
    local cyrillic = nick:match("([%a]+)")
    if cyrillic and #cyrillic >= 2 then return cyrillic:sub(1, 14) end
    if #nick >= 2 then return nick:sub(1, 14) end
    return nil
end

local function trimToMax(s, max)
    s = tostring(s or "")
    if #s <= max then return s end
    return string.sub(s, 1, max)
end

-- §HTTP
local function postJson(url, headers, bodyTable)
    local body
    local encOk, encErr = pcall(function()
        body = HttpService:JSONEncode(bodyTable)
    end)
    if not encOk then
        return nil, 0, "JSONEncodeFailed", tostring(encErr):sub(1,100), {}
    end

    local httprequest = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request
    if not httprequest then
        return nil, 500, "ExecutorHttpNotSupported", "This script requires an executor with a custom HTTP request function.", {}
    end

    local callOk, response = pcall(httprequest, {
        Url     = url,
        Method  = "POST",
        Headers = headers,
        Body    = body,
    })
    if not callOk then
        return nil, 0, "RequestFailed", tostring(response):sub(1, 200), {}
    end
    if type(response) ~= "table" then
        return nil, 0, "BadResponse", "httprequest returned non-table", {}
    end

    local respBody    = tostring(response.Body or response.body or "")
    local respStatus  = tonumber(response.StatusCode or response.statusCode or response.Status or response.status) or 200
    local respMsg     = tostring(response.StatusMessage or response.statusMessage or "Unknown")
    local respHeaders = response.Headers or response.headers or {}

    if respStatus < 200 or respStatus >= 300 then
        return nil, respStatus, respMsg, respBody, respHeaders
    end
    if respBody == "" then
        return nil, respStatus, "EmptyBody", "Server returned empty response", respHeaders
    end

    local decoded
    local ok, err = pcall(function()
        decoded = HttpService:JSONDecode(respBody)
    end)
    if not ok then
        return nil, respStatus, "JSONDecodeFailed", tostring(err):sub(1,200), respHeaders
    end
    return decoded, respStatus, nil, nil, respHeaders
end

