-- §PARSE_ACTION
local function parseActionTag(text)
    if not text then return nil, "" end
    local action, cleanText = nil, text
    local tagStart, tagEnd, captured = text:find("%[%s*[Dd][Oo]:%s*([%w_]+)%s*%]")
    if tagStart then
        action    = captured:lower()
        cleanText = text:sub(1, tagStart - 1) .. text:sub(tagEnd + 1)
    else
        tagStart, tagEnd, captured = text:find("%[%s*[Dd][Oo]:%s*([%w_]+)")
        if tagStart then
            action    = captured:lower()
            local rest = text:sub(tagEnd + 1):gsub("^%s*%]?%s*", "")
            cleanText = text:sub(1, tagStart - 1) .. rest
        end
    end
    cleanText = cleanText:gsub("%[%s*[Dd][Oo]:%s*[%w_]+%s*%]?", "")
    cleanText = cleanText:gsub("%[%s*%]", "")
    cleanText = cleanText:gsub("%s+", " "):match("^%s*(.-)%s*$") or ""
    return action, cleanText
end

local function executeAction(actionName, sourcePlayer, cleanText, originalUserMsg)
    if actionName and ClientSettings.ActionsEnabled then
        if actionName == "jump" and originalUserMsg then
            local msg = originalUserMsg:lower()
            local n   = msg:match("(%d+)%s*ра[зза]")
                     or msg:match("(%d+)%s*прыжк")
                     or msg:match("(%d+)%s*times?")
                     or msg:match("jump%s*(%d+)")
                     or msg:match("прыгни%s*(%d+)")
            if n then
                n = math.max(1, math.min(tonumber(n) or 1, 10))
                if n > 1 then
                    task.spawn(function() doJump(n) end)
                    return cleanText or ""
                end
            end
        end
        local handler = ACTION_HANDLERS[actionName]
        if handler then
            task.spawn(function()
                local ok, err = pcall(handler, sourcePlayer)
                if not ok and ClientSettings.Debug then
                    print("[LOB] action error [" .. tostring(actionName) .. "]: " .. tostring(err))
                end
            end)
        end
    end
    return cleanText or ""
end

