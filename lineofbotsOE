        knob.BackgroundColor3=Color3.fromRGB(255,255,255); knob.BorderSizePixel=0; knob.Parent=switchBg; makeCorner(knob,9)
        local function startAurora() switchBg.BackgroundColor3=THEME.ToggleOn; TweenService:Create(switchStroke,TWEEN_MED,{Transparency=0.65}):Play() end
        local function stopAurora()  switchBg.BackgroundColor3=THEME.ToggleOff; TweenService:Create(switchStroke,TWEEN_MED,{Transparency=0.92}):Play() end
        if initialState then switchBg.BackgroundColor3=THEME.ToggleOn end
        local hit=Instance.new("TextButton"); hit.Name="Hit"; hit.Text=""
        hit.BackgroundTransparency=1; hit.Size=UDim2.new(1,0,1,0); hit.Parent=row
