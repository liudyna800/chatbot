    local function ctDoSend()
        local rawMsg=ctInputBox.Text:gsub("^%s+",""):gsub("%s+$","")
        if rawMsg=="" or ctSending then return end
        local msg=rawMsg
        if ClientSettings.StripHash~=false then msg=msg:gsub("#",""):gsub("%s+"," "):match("^%s*(.-)%s*$") end
        if msg=="" then return end
        ctSending=true; ctInputBox.Text=""
        ctSendBtn.BackgroundTransparency=0.7; ctSendBtn.Text="..."
        local function unblockSend()
            ctSending=false; pcall(function() ctSendBtn.BackgroundTransparency=0.4; ctSendBtn.Text=">>" end)
        end
        ctAddMessage(rawMsg,false,false)
        ctMsgCounter=ctMsgCounter+1
        local typingIdx=ctMsgCounter
        local typingBubble=Instance.new("Frame"); typingBubble.BackgroundTransparency=1; typingBubble.Size=UDim2.new(1,0,0,26); typingBubble.LayoutOrder=typingIdx; typingBubble.Parent=ctLog
