local function makeToggleRow(parent, labelText, descText, initialState, onChanged)
    local row = Instance.new("Frame")
    row.Name = labelText:gsub("%W+", "") .. "Row"
    row.BackgroundColor3 = THEME.Button
    row.BackgroundTransparency = THEME.ButtonTransparency or 0.60
    row.BorderSizePixel = 0
    row.Size = UDim2.new(1, -8, 0, descText and descText ~= "" and 56 or 46)
    row.Parent = parent
    makeCorner(row, 22)
    local st = makeStroke(row, 1, Color3.fromRGB(255,255,255), 0.78)

    -- Точка-индикатор — выравниваем по строке заголовка, не по центру всего row
    local dot = Instance.new("Frame")
    dot.Size = UDim2.new(0, 6, 0, 6)
    dot.AnchorPoint = Vector2.new(0, 0.5)
    -- Если есть описание: заголовок на y=8, высота 18 → центр заголовка на y=17
    -- Если нет описания: центр row
    dot.Position = UDim2.new(0, 8, 0, hasDesc and 17 or 0)
    if not hasDesc then
        dot.AnchorPoint = Vector2.new(0, 0.5)
        dot.Position = UDim2.new(0, 8, 0.5, 0)
    end
    dot.BackgroundColor3 = initialState and Color3.fromRGB(80, 220, 120) or Color3.fromRGB(80, 80, 100)
    dot.BackgroundTransparency = 0
    dot.BorderSizePixel = 0
    dot.ZIndex = 3
    dot.Parent = row
    makeCorner(dot, 999)

    local hasDesc = descText and descText ~= ""
    local label = makeTextLabel(row, labelText, 13, "semibold")
    label.Name = "Label"
    -- Отступ слева учитывает: 8px до точки + 6px точка + 6px зазор = 20px, справа 14px для switch
    label.Size = UDim2.new(1, -90, 0, 18)
    label.Position = hasDesc and UDim2.new(0, 22, 0, 8) or UDim2.new(0, 22, 0.5, -9)

    if hasDesc then
        local desc = makeTextLabel(row, descText, 11, "medium")
        desc.Name = "Description"
        desc.TextColor3 = THEME.TextDim
        desc.Position = UDim2.new(0, 22, 0, 27)
        desc.Size = UDim2.new(1, -90, 0, 16)
        desc.TextTruncate = Enum.TextTruncate.AtEnd
        desc.ClipsDescendants = false
    end

    -- v17.5: Крупный красивый переключатель
    local switchBg = Instance.new("Frame")
    switchBg.Name = "SwitchBg"
    switchBg.Size = UDim2.new(0, 44, 0, 24)
    switchBg.AnchorPoint = Vector2.new(1, 0.5)
    switchBg.Position = UDim2.new(1, -10, 0.5, 0)
    switchBg.BackgroundColor3 = initialState and THEME.ToggleOn or THEME.ToggleOff
    switchBg.BorderSizePixel = 0
    switchBg.Parent = row
    makeCorner(switchBg, 14)
    local switchStroke = Instance.new("UIStroke")
    switchStroke.Color = Color3.fromRGB(255,255,255)
    switchStroke.Transparency = initialState and 0.7 or 0.92
    switchStroke.Thickness = 1
    switchStroke.Parent = switchBg

    local knob = Instance.new("Frame")
    knob.Name = "Knob"
    knob.Size = UDim2.new(0, 18, 0, 18)
    knob.AnchorPoint = Vector2.new(0, 0.5)
    knob.Position = initialState and UDim2.new(0, 23, 0.5, 0) or UDim2.new(0, 3, 0.5, 0)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    knob.BorderSizePixel = 0
    knob.Parent = switchBg
    makeCorner(knob, 9)

    -- Чистая анимация без накапливающихся Heartbeat loops
    local function startAurora()
        -- Просто ставим цвет темы — без RunService loop
        switchBg.BackgroundColor3 = THEME.ToggleOn
        TweenService:Create(switchStroke, TWEEN_MED, { Transparency = 0.65 }):Play()
    end
    local function stopAurora()
        switchBg.BackgroundColor3 = THEME.ToggleOff
        TweenService:Create(switchStroke, TWEEN_MED, { Transparency = 0.92 }):Play()
    end
    if initialState then switchBg.BackgroundColor3 = THEME.ToggleOn end

    local hit = Instance.new("TextButton")
    hit.Name = "Hit"
    hit.Text = ""
    hit.BackgroundTransparency = 1
    hit.Size = UDim2.new(1, 0, 1, 0)
    hit.Parent = row

    hit.MouseEnter:Connect(function()
        tween(row, TWEEN_FAST, { BackgroundColor3 = THEME.ButtonHover })
    end)
    hit.MouseLeave:Connect(function()
        tween(row, TWEEN_FAST, { BackgroundColor3 = THEME.Card })
    end)

    local state = initialState and true or false
    hit.MouseButton1Click:Connect(function()
        state = not state
        if state then
            startAurora()
            tween(knob, TWEEN_MED, { Position = UDim2.new(0, 23, 0.5, 0) })
            tween(dot, TWEEN_MED, { BackgroundColor3 = Color3.fromRGB(80, 220, 120), BackgroundTransparency = 0 })
            TweenService:Create(switchStroke, TWEEN_MED, { Transparency = 0.7 }):Play()
        else
            stopAurora()
            tween(knob, TWEEN_MED, { Position = UDim2.new(0, 3, 0.5, 0) })
            tween(dot, TWEEN_MED, { BackgroundColor3 = Color3.fromRGB(60, 60, 85), BackgroundTransparency = 0 })
            TweenService:Create(switchStroke, TWEEN_MED, { Transparency = 0.92 }):Play()
        end
        if onChanged then onChanged(state) end
    end)

    return {
        Get = function() return state end,
        Set = function(v)
            state = not not v
            if state then startAurora() else stopAurora() end
            knob.Position = state and UDim2.new(0, 23, 0.5, 0) or UDim2.new(0, 3, 0.5, 0)
            dot.BackgroundColor3 = state and Color3.fromRGB(80, 220, 120) or Color3.fromRGB(60, 60, 85)
            dot.BackgroundTransparency = 0
            switchStroke.Transparency = state and 0.7 or 0.92
        end,
    }
end

