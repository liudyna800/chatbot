    -- R15
    if builtinName then
        local ok, played = pcall(function() return humanoid:PlayEmote(builtinName) end)
        if ok and played then
            if duration then
                _activeEmoteThread = task.delay(duration, function()
                    local hum2     = getLocalHumanoid()
                    local animator = hum2 and hum2:FindFirstChildOfClass("Animator")
                    if animator then
                        pcall(function()
                            for _, t in ipairs(animator:GetPlayingAnimationTracks()) do
