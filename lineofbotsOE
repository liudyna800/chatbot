-- TAB 3: API КЛЮЧИ
-- ══════════════════════════════════════
do
    local T = tabFrames[3]

    -- helper: карточка с ключом + кнопка Проверить + статус
    local function MakeKeyCard(parent, title, getKey, setKey, testFn)
        local card = MakeCard(parent, 110)
        MakeLabel(card, title, UDim2.new(1,-20,0,16), UDim2.new(0,12,0,6), 11, true, Color3.fromRGB(170,150,220))

        local box = Instance.new("TextBox")
        box.Size = UDim2.new(1,-20,0,30); box.Position = UDim2.new(0,10,0,26)
        box.BackgroundColor3 = Color3.fromRGB(10,8,24); box.Text = getKey()
        box.PlaceholderText = "Вставь ключ сюда..."; box.TextColor3 = Color3.fromRGB(218,208,252)
        box.PlaceholderColor3 = Color3.fromRGB(70,60,110); box.Font = Enum.Font.RobotoMono
        box.TextSize = 11; box.ClearTextOnFocus = false; box.ZIndex = 13; box.Parent = card
        do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,7); c.Parent = box end
        local bs = Instance.new("UIStroke"); bs.Color = Color3.fromRGB(60,45,120); bs.Thickness = 1; bs.Parent = box
        box.Focused:Connect(function() TweenService:Create(bs,TweenInfo.new(0.15),{Color=Color3.fromRGB(110,65,210),Thickness=1.5}):Play() end)
        box.FocusLost:Connect(function()
            TweenService:Create(bs,TweenInfo.new(0.15),{Color=Color3.fromRGB(60,45,120),Thickness=1}):Play()
            if box.Text ~= "" then setKey(box.Text); SaveCfg() end
        end)

        -- статус лейбл
        local statusLabel = Instance.new("TextLabel")
        statusLabel.Size = UDim2.new(1,-130,0,20); statusLabel.Position = UDim2.new(0,12,0,62)
        statusLabel.BackgroundTransparency = 1; statusLabel.Text = ""
        statusLabel.Font = Enum.Font.RobotoMono; statusLabel.TextSize = 11
        statusLabel.TextColor3 = Color3.fromRGB(140,130,180)
        statusLabel.TextXAlignment = Enum.TextXAlignment.Left; statusLabel.ZIndex = 13; statusLabel.Parent = card

        -- кнопка проверки
        local checkBtn = Instance.new("TextButton")
        checkBtn.Size = UDim2.new(0,108,0,26); checkBtn.Position = UDim2.new(1,-118,0,60)
        checkBtn.BackgroundColor3 = Color3.fromRGB(40,28,90); checkBtn.Text = "✓  Проверить"
        checkBtn.Font = Enum.Font.GothamBold; checkBtn.TextSize = 11
        checkBtn.TextColor3 = Color3.fromRGB(190,170,240); checkBtn.AutoButtonColor = false
        checkBtn.ZIndex = 13; checkBtn.Parent = card
        do local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,7); c.Parent = checkBtn end
        do local s = Instance.new("UIStroke"); s.Color = Color3.fromRGB(75,52,160); s.Thickness = 1; s.Parent = checkBtn end

        checkBtn.MouseButton1Click:Connect(function()
            local key = box.Text
            if key == "" then statusLabel.Text = "⚠ Ключ не введён"; statusLabel.TextColor3 = Color3.fromRGB(220,180,60); return end
            setKey(key); SaveCfg()
            checkBtn.Text = "⏳ Проверка..."
            checkBtn.TextColor3 = Color3.fromRGB(180,160,220)
            statusLabel.Text = ""; task.spawn(function()
                local ok, msg = testFn(key)
                if ok then
                    statusLabel.Text = "✅ Ключ работает!"; statusLabel.TextColor3 = Color3.fromRGB(80,220,130)
                    checkBtn.Text = "✅ OK"; checkBtn.TextColor3 = Color3.fromRGB(80,220,130)
                    TweenService:Create(checkBtn,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(20,70,40)}):Play()
                else
                    statusLabel.Text = "❌ "..tostring(msg); statusLabel.TextColor3 = Color3.fromRGB(220,70,80)
                    checkBtn.Text = "❌ Ошибка"; checkBtn.TextColor3 = Color3.fromRGB(220,70,80)
                    TweenService:Create(checkBtn,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(70,20,25)}):Play()
                end
                task.delay(4, function()
                    if checkBtn and checkBtn.Parent then
                        checkBtn.Text = "✓  Проверить"; checkBtn.TextColor3 = Color3.fromRGB(190,170,240)
                        TweenService:Create(checkBtn,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(40,28,90)}):Play()
                    end
                end)
            end)
        end)
        return card
    end

    -- тест Groq
    local function TestGroq(key)
        local body = HttpService:JSONEncode({
            model = Cfg.GroqModel,
            messages = {{role="user", content="Hi"}},
            max_tokens = 5,
        })
        local res = DoRequest("https://api.groq.com/openai/v1/chat/completions","POST",
            {["Content-Type"]="application/json",["Authorization"]="Bearer "..key}, body)
        if not res then return false, "Нет ответа" end
        if res.StatusCode == 200 then return true, nil end
        if res.StatusCode == 401 then return false, "Неверный ключ (401)" end
        if res.StatusCode == 429 then return false, "Rate limit (429)" end
        return false, "HTTP "..tostring(res.StatusCode)
    end

    -- тест Gemini
    local function TestGemini(key)
        local body = HttpService:JSONEncode({
            model = Cfg.GeminiModel,
            messages = {{role="user", content="Hi"}},
            max_tokens = 5,
            reasoning_effort = "none",
        })
        local res = DoRequest("https://generativelanguage.googleapis.com/v1beta/openai/chat/completions","POST",
            {["Content-Type"]="application/json",["Authorization"]="Bearer "..key}, body)
        if not res then return false, "Нет ответа" end
        if res.StatusCode == 200 then return true, nil end
        if res.StatusCode == 401 or res.StatusCode == 400 then return false, "Неверный ключ" end
        if res.StatusCode == 429 then return false, "Rate limit (429)" end
        return false, "HTTP "..tostring(res.StatusCode)
    end

    MakeSectionLabel(T, "── GROQ  (3 ключа, round-robin) ──")

    for i = 1, 3 do
        local ci = i
        MakeKeyCard(T,
            "Groq ключ #"..i.."  (gsk_...)",
            function() return Cfg.GroqKeys[ci] or "" end,
            function(v) Cfg.GroqKeys[ci] = v end,
            TestGroq
        )
    end

    MakeSectionLabel(T, "── GEMINI ──")

    MakeKeyCard(T,
        "Google Gemini API ключ  (AIzaSy...)",
        function() return Cfg.GeminiKey end,
        function(v) Cfg.GeminiKey = v end,
        TestGemini
    )

    MakeSectionLabel(T, "── ИНСТРУМЕНТЫ ──")
    MakeButton(T, "🔄  Сбросить кулдауны Groq слотов", Color3.fromRGB(48,30,100), function()
        Cfg.GroqCooldowns = {0,0,0}
    end)
end

