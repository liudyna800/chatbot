local function makeTabFrame(id)
    local f = Instance.new("CanvasGroup")
    f.Name                   = id
    f.BackgroundTransparency = 1
    f.Size                   = UDim2.new(1, 0, 1, 0)
    f.Visible                = false
    f.GroupTransparency      = 1
    f.Parent                 = content
    tabFrames[id]            = f
    return f
end

-- ── Функция переключения ───────────────────────────────
local switching = false
local function switchTab(id)
    if id == activeTab or switching then return end
    switching = true

    -- Скрываем старый
    if activeTab and tabFrames[activeTab] then
        local old2 = tabFrames[activeTab]
        tw(old2, tw_fast, {GroupTransparency = 1})
        task.delay(0.15, function()
            if old2 then old2.Visible = false end
        end)
        if tabButtons[activeTab] then tabButtons[activeTab].setActive(false) end
    end

    -- Показываем новый
    activeTab = id
    if tabFrames[id] then
        local nf = tabFrames[id]
        nf.GroupTransparency = 1
        nf.Visible = true
        tw(nf, tw_med, {GroupTransparency = 0})
    end
    if tabButtons[id] then tabButtons[id].setActive(true) end

    task.delay(0.3, function() switching = false end)
end

