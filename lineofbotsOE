-- ══════════════════════════════════════════════════════
-- §TAB_SYSTEM  — система вкладок
-- ══════════════════════════════════════════════════════
local tabFrames  = {}
local tabBtns    = {}
local activeTab  = nil
local tabBusy    = false

local function makeTabFrame(id)
    local cg = Instance.new("CanvasGroup")
    cg.Name                   = "Tab_"..id
    cg.BackgroundTransparency = 1
    cg.Size                   = UDim2.new(1, 0, 1, 0)
    cg.Position               = UDim2.new(0, 0, 0, 0)
    cg.GroupTransparency      = 1
    cg.Visible                = false
    cg.Parent                 = content
    tabFrames[id]             = cg
    return cg
end

local function switchTab(id)
    if id == activeTab or tabBusy then return end
    tabBusy = true

    -- Скрываем старый таб
    if activeTab and tabFrames[activeTab] then
        local prev = tabFrames[activeTab]
        tw(prev, TI.fast, {GroupTransparency=1})
        task.delay(0.15, function()
            if prev and prev.Parent then prev.Visible = false end
        end)
        -- Убираем подсветку кнопки
        if tabBtns[activeTab] then
            local b = tabBtns[activeTab]
            tw(b.btn, TI.fast, {BackgroundTransparency=1, BackgroundColor3=C.BgSide})
            tw(b.lbl, TI.fast, {TextColor3=C.TextMid})
            tw(b.ico, TI.fast, {TextColor3=C.TextDim})
            tw(b.bar, TI.fast, {BackgroundTransparency=1})
        end
    end

    activeTab = id

    -- Показываем новый таб
    if tabFrames[id] then
        local nxt = tabFrames[id]
        nxt.GroupTransparency = 1
        nxt.Visible = true
        tw(nxt, TI.med, {GroupTransparency=0})
    end
    -- Подсвечиваем кнопку
    if tabBtns[id] then
        local b = tabBtns[id]
        tw(b.btn, TI.fast, {BackgroundTransparency=0, BackgroundColor3=C.BgHover})
        tw(b.lbl, TI.fast, {TextColor3=C.Text})
        tw(b.ico, TI.fast, {TextColor3=C.Accent})
        tw(b.bar, TI.fast, {BackgroundTransparency=0})
    end

    task.delay(0.28, function() tabBusy = false end)
end

