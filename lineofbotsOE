-- v17.5: Детектор языка + кеш последнего языка каждого игрока
-- Проблема: эмодзи/одна буква → detectLang возвращает nil → фолбэк на кеш
local _userLangCache = {}  -- userId → "RU"|"EN"

local function detectLang(text)
    if not text or text == "" then return nil end
    local t = text:lower()
    local cyr = 0
    for _ in t:gmatch("[\208-\209][\128-\191]") do cyr = cyr + 1 end
    local lat = 0
    for _ in t:gmatch("[a-z]+") do lat = lat + 1 end
    if cyr > 1 then return "RU" end
    if lat > 0 then return "EN" end
    return nil  -- не определили (эмодзи, цифры, одна буква)
end

-- Получить язык: определяем → кешируем → при неопределённом берём кеш
local function getLangForUser(text, userId)
    local lang = detectLang(text)
    if lang then
        if userId then _userLangCache[userId] = lang end
        return lang
    end
    if userId and _userLangCache[userId] then
        return _userLangCache[userId]
    end
    return "OTHER"
end

-- Безопасно добавить пару в историю и обрезать до лимита
local function appendHistory(history, userMsg, assistantMsg)
    table.insert(history, { role = "user",      content = userMsg      })
    table.insert(history, { role = "assistant", content = assistantMsg })
    -- Обрезаем: каждая пара = 2 элемента, оставляем MAX_HISTORY пар
    local maxItems = MAX_HISTORY * 2
    while #history > maxItems do
        table.remove(history, 1)
    end
end

-- Возвращает таблицу истории для данного вызова.
-- Если память выключена (MemoryEnabled=false) — возвращает nil.
-- handleQueuedChat проверяет nil и не добавляет контекст.
local function getHistory(settings, userId)
    if not settings.MemoryEnabled then
        return nil -- память выключена
    end
    if settings.PerUserMemory then
        -- Отдельная история для каждого игрока
        if not ChatHistory[userId] then ChatHistory[userId] = {} end
        return ChatHistory[userId]
    else
        -- Одна общая история для всех
        if not ChatHistory["Global"] then ChatHistory["Global"] = {} end
        return ChatHistory["Global"]
    end
end

local function handleQueuedChat(item)
    local settings = ClientSettings
    -- world reactions (item.isWorld) работают даже без AutoReply — только Enabled нужен
    if not settings.Enabled then return end
    if not item.isWorld and not settings.AutoReply then return end

    -- history = nil если память выключена
    local history = getHistory(settings, item.userId)

    -- Собираем сообщения для API
    local apiMessages = {}
    table.insert(apiMessages, { role = "system", content = makeSystemPrompt(settings) })

    -- Добавляем историю — полностью, по настройке MAX_HISTORY
    -- TokenEconomy НЕ обрезает историю (память святая), только укорачивает промпт и max_tokens
    if history then
        -- appendHistory уже хранит не более MAX_HISTORY пар,
        -- но MAX_HISTORY мог увеличиться — поэтому берём ровно MAX_HISTORY последних пар
        local maxItems = MAX_HISTORY * 2
        local startIdx = math.max(1, #history - maxItems + 1)
        for i = startIdx, #history do
            table.insert(apiMessages, history[i])
        end
    end

    -- UsePlayerName
    -- UsePlayerName: имя игрока в тег [NAME:X]
    -- item.name = Username (всегда латиница), item.displayName = DisplayName (может быть кириллица/цифры)
    local userContent = item.cleaned
    if settings.UsePlayerName then
        local shortName = extractShortName(item.name or "")  -- username первый (надёжнее)
        if not shortName then
            shortName = extractShortName(item.displayName or "")  -- displayName второй
        end
        if not shortName then
            -- Последний фолбэк: обрезаем username напрямую
            local fallback = item.name or item.displayName or ""
            if #fallback >= 2 then shortName = fallback:sub(1, 14) end
        end
        if shortName then
            userContent = "[NAME:" .. shortName .. "] " .. item.cleaned
        end
    end

    -- v17: PlayerAwareness — добавляем контекст о ближайших игроках ПЕРЕД user message
    if settings.PlayerAwareness then
        local nearbyCtx = buildPlayerAwarenessContext(settings)
        -- Вставляем только если рядом есть игроки (пустая строка = никого нет)
        if nearbyCtx ~= "" then
            table.insert(apiMessages, {
                role    = "system",
                content = "CURRENT SURROUNDINGS (live snapshot):" .. nearbyCtx
            })
        end

        -- Проактивный токсик-алерт: если обнаружен токсик — добавляем явный алерт
        -- Работает ДАЖЕ если в [NEARBY] его нет (например игрок вышел из зоны после детекта)
        local toxicNames = {}
        for uid, tname in pairs(_toxicAlerts) do
            table.insert(toxicNames, tostring(tname))
            _toxicAlerts[uid] = nil  -- очищаем после использования (не повторяем вечно)
        end
        if #toxicNames > 0 then
            table.insert(apiMessages, {
                role    = "system",
                content = "⚠ TOXIC BEHAVIOR DETECTED: player(s) [" .. table.concat(toxicNames, ", ") 
                    .. "] were repeatedly moving back-and-forth behind you. React naturally — call them out, say you noticed, or warn them."
            })
        end
    end

    -- world items отвечаем на языке личности (RU), не детектируем язык [SYSTEM:] текста
    local langTag = item.isWorld and "RU" or getLangForUser(item.cleaned, item.userId)
    table.insert(apiMessages, { role = "user", content = "[LANG:" .. langTag .. "] " .. userContent })

    local model = getModel(settings)
    if model == "" then return end

    -- В экономном режиме max_tokens тоже уменьшаем (короткие ответы)
    local maxTok = tonumber(settings.MaxTokens) or 512
    if settings.TokenEconomy then
        maxTok = math.min(maxTok, 150)
    end

    local payload = {
        model       = model,
        temperature = tonumber(settings.Temperature) or 0.7,
        max_tokens  = maxTok,
        messages    = apiMessages,
    }
    -- Qwen3 отключаем reasoning
    if model == "qwen/qwen3-32b" then
        payload.reasoning_effort = "none"
    end

    local text, err = providerRouter:chatCompletions(payload)
    -- v18: при rate limit (429) — ждём 5 сек и повторяем один раз, не отключаем бота
    if (not text or text == "") and err and tostring(err):find("429") then
        task.wait(5)
        text, err = providerRouter:chatCompletions(payload)
    end
    if err or not text or text == "" then
        return
    end

    -- FIX: удаляем [NAME:...] теги из ответа ИИ если модель их нечаянно скопировала
    -- Это надёжнее чем надеяться только на промпт
    text = text:gsub("%[NAME:[^%]]*%]%s*", "")

    -- v17: поворачиваемся к говорящему игроку (если CameraLook включён)
    if item.player and item.player.Character then
        local pRoot = item.player.Character:FindFirstChild("HumanoidRootPart")
        if pRoot then
            smoothLookAt(pRoot.Position)
        end
    end

    -- v16: парсим тег [DO:xxx] из ответа ИИ
    -- parseActionTag возвращает (actionName, cleanText) — оба нужны
    local actionName, cleanText = parseActionTag(text)
    cleanText = executeAction(actionName, item.player, cleanText, item.cleaned)

    -- Сохраняем в историю только если память включена
    -- ВАЖНО: сохраняем userContent (с [NAME:X] если UsePlayerName включён) — 
    -- так ИИ в глобальной памяти помнит кто что говорил.
    -- [LANG:X] тег НЕ сохраняем (он нужен только для текущего запроса).
    if history then
        -- Убираем [LANG:...] тег из финального сохранения в историю
        local historyUserMsg = item.cleaned
        if settings.UsePlayerName and userContent ~= item.cleaned then
            -- Берём userContent но без [LANG:...] тега если он туда попал
            historyUserMsg = userContent:gsub("%[LANG:[^%]]*%]%s*", "")
        end
        appendHistory(history, historyUserMsg, cleanText)
    end

    sendBotMessage(cleanText)
end

local function runChatQueue(userId)
    local q = getChatQueue(userId)
    if q.running then
        return
    end
    q.running = true
    task.spawn(function()
        while true do
            local item = dequeueChatItem(q)
            if not item then
                break
            end
            handleQueuedChat(item)
            if q.head <= q.tail then
                task.wait()
            end
        end
        q.running = false
    end)
end

