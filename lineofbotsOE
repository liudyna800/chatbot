local function isBlacklisted(settings, userId)
    -- New structured blacklist support
    local bl = settings.Blacklist
    if type(bl) == "table" then
        local perm = bl.Permanent
        if type(perm) == "table" then
            if perm[userId] == true then
                return true
            end
            for _, id in ipairs(perm) do
                if id == userId then
                    return true
                end
            end
        end

        local tmp = bl.Temporary
        if type(tmp) == "table" then
            local exp = tmp[userId]
            if type(exp) == "number" then
                if os.time() < exp then
                    return true
                else
                    tmp[userId] = nil
                end
            end
        end
    end

    local list = settings.BlacklistUserIds
    if type(list) ~= "table" then
        return false
    end
    for _, id in ipairs(list) do
        if id == userId then
            return true
        end
    end
    return false
end

local function passesTrigger(settings, message)
    local trigger = settings.Trigger
    if type(trigger) ~= "table" then
        return true
    end
    
    local mode = trigger.Mode
    if mode == "all" then
        return true
    end
    
    local prefix = trigger.Prefix
    if type(prefix) ~= "string" or prefix == "" then
        return true
    end
    
    return string.sub(message, 1, #prefix) == prefix
end

local function stripTrigger(settings, message)
    local trigger = settings.Trigger
    if type(trigger) ~= "table" then
        return message
    end
    
    local mode = trigger.Mode
    if mode ~= "prefix" then
        return message
    end
    
    local prefix = trigger.Prefix
    if type(prefix) ~= "string" or prefix == "" then
        return message
    end
    
    if string.sub(message, 1, #prefix) == prefix then
        local rest = string.sub(message, #prefix + 1)
        return rest
    end
    
    return message
end

-- Разбить текст на части по MAX символов, стараясь резать по пробелу/знаку
local function splitTextIntoParts(text, maxLen)
    local parts = {}
    maxLen = maxLen or 200
    while #text > maxLen do
        -- Ищем последний пробел в пределах maxLen
        local cutPos = maxLen
        for i = maxLen, math.max(1, maxLen - 40), -1 do
            if text:sub(i, i) == " " then
                cutPos = i - 1
                break
            end
        end
        table.insert(parts, text:sub(1, cutPos))
        text = text:sub(cutPos + 2) -- +2 чтобы пропустить пробел
        -- Убираем пробелы в начале следующей части
        text = text:match("^%s*(.-)%s*$") or text
    end
    if #text > 0 then
        table.insert(parts, text)
    end
    return parts
end

local function sendBotMessage(text)
    -- Убираем служебные теги которые ИИ иногда копирует в ответ
    text = text:gsub("%[LANG:[^%]]*%]%s*", "")
    text = text:gsub("%[NAME:[^%]]*%]%s*", "")
    text = normalizeOneLine(text)
    if text == "" then return end

    local maxLen = Constants.MaxResponseChars  -- 200 по умолчанию

    if #text <= maxLen then
        -- Короткий текст — отправляем сразу
        showBotChatMessage(text, true)
    else
        -- Длинный — разбиваем на части
        local parts = splitTextIntoParts(text, maxLen)
        for i, part in ipairs(parts) do
            if part ~= "" then
                showBotChatMessage(part, true)
                if i < #parts then
                    task.wait(1.2)  -- пауза между частями
                end
            end
        end
    end
end

