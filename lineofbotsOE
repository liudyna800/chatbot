local function GetAvatarUrl(userId)
    local res = DoRequest(
        "https://thumbnails.roblox.com/v1/users/avatar-headshot?userIds=" .. tostring(userId) .. "&size=420x420&format=Png&isCircular=false",
        "GET",
        {["Accept"] = "application/json"}
    )
    if not res or res.StatusCode ~= 200 then return nil end
    local ok, data = pcall(HttpService.JSONDecode, HttpService, res.Body)
    if not ok or not data or not data.data or not data.data[1] then return nil end
    return data.data[1].imageUrl
end

local function DescribeAvatar(userId, username)
    if AvatarCache[userId] then return AvatarCache[userId] end
    local url = GetAvatarUrl(userId)
    if not url then return nil end

    local body = HttpService:JSONEncode({
        model = "openai",
        messages = {{
            role = "user",
            content = {
                {type = "text", text = "Roblox avatar of " .. username .. ". In one sentence describe what they look like. Be concise."},
                {type = "image_url", image_url = {url = url}},
            }
        }},
        max_tokens = 60,
        temperature = 0.5,
    })

    local res = DoRequest(
        "https://text.pollinations.ai/openai",
        "POST",
        {["Content-Type"] = "application/json", ["Accept"] = "application/json"},
        body
    )
    if not res or res.StatusCode ~= 200 then return nil end
    local ok, data = pcall(HttpService.JSONDecode, HttpService, res.Body)
    if not ok or not data or not data.choices or not data.choices[1] then return nil end
    local desc = data.choices[1].message and data.choices[1].message.content
    if desc and desc ~= "" then
        AvatarCache[userId] = desc
        return desc
    end
    return nil
end

-- ═══════════════════════════════════════════════════════════
-- GROQ ROUND-ROBIN
-- ═══════════════════════════════════════════════════════════
local function GetGroqKey()
    local now = tick()
    -- ищем слот у которого прошёл кулдаун
    for offset = 0, 2 do
        local slot = ((Cfg.GroqSlot - 1 + offset) % 3) + 1
        local key  = Cfg.GroqKeys[slot]
        if key and key ~= "" then
            local cd = Cfg.GroqCooldowns[slot] or 0
            if now - cd >= Cfg.GroqKeyCooldown then
                Cfg.GroqSlot = (slot % 3) + 1
                Cfg.GroqCooldowns[slot] = now
                return key, slot
            end
        end
    end
    -- все на кулдауне — ждём ближайший
    local minWait = math.huge
    for slot = 1, 3 do
        if Cfg.GroqKeys[slot] and Cfg.GroqKeys[slot] ~= "" then
            local wait = Cfg.GroqKeyCooldown - (now - (Cfg.GroqCooldowns[slot] or 0))
            if wait < minWait then minWait = wait end
        end
    end
    if minWait > 0 and minWait < math.huge then
        task.wait(minWait + 0.5)
        return GetGroqKey()
    end
    return nil, nil
end

-- ═══════════════════════════════════════════════════════════
-- API CALLS
-- ═══════════════════════════════════════════════════════════
local function CallGroq(messages)
    local key, slot = GetGroqKey()
    if not key then
        warn("[LOB] Все Groq ключи на кулдауне!")
        return nil, "rate_limit"
    end

    local body = HttpService:JSONEncode({
        model       = Cfg.GroqModel,
        messages    = messages,
        max_tokens  = Cfg.MaxTokens,
        temperature = Cfg.Temperature,
        stream      = false,
    })

    local res = DoRequest(
        "https://api.groq.com/openai/v1/chat/completions",
        "POST",
        {
            ["Content-Type"]  = "application/json",
            ["Authorization"] = "Bearer " .. key,
        },
        body
    )

    if not res then return nil, "no_response" end
    if res.StatusCode == 429 then
        -- этот слот снова на кулдауне
        Cfg.GroqCooldowns[slot] = tick() + Cfg.GroqKeyCooldown
        warn("[LOB] Groq slot " .. slot .. " rate limited, пробуем следующий...")
        return CallGroq(messages)
    end
    if res.StatusCode ~= 200 then
        warn("[LOB] Groq HTTP " .. tostring(res.StatusCode))
        return nil, "http_" .. tostring(res.StatusCode)
    end

    local ok, data = pcall(HttpService.JSONDecode, HttpService, res.Body)
    if not ok or not data or not data.choices or not data.choices[1] then
        return nil, "parse_error"
    end
    return data.choices[1].message and data.choices[1].message.content, nil
end

local function CallGemini(messages)
    if not Cfg.GeminiKey or Cfg.GeminiKey == "" then
        return nil, "no_key"
    end

    local body = HttpService:JSONEncode({
        model           = Cfg.GeminiModel,
        messages        = messages,
        max_tokens      = Cfg.MaxTokens,
        temperature     = Cfg.Temperature,
        stream          = false,
        reasoning_effort = "none",   -- фикс тишины в 2.5-flash
    })

    local res = DoRequest(
        "https://generativelanguage.googleapis.com/v1beta/openai/chat/completions",
        "POST",
        {
            ["Content-Type"]  = "application/json",
            ["Authorization"] = "Bearer " .. Cfg.GeminiKey,
        },
        body
    )

    if not res then return nil, "no_response" end
    if res.StatusCode == 429 then return nil, "rate_limit" end
    if res.StatusCode ~= 200 then
        warn("[LOB] Gemini HTTP " .. tostring(res.StatusCode))
        return nil, "http_" .. tostring(res.StatusCode)
    end

    local ok, data = pcall(HttpService.JSONDecode, HttpService, res.Body)
    if not ok or not data or not data.choices or not data.choices[1] then
        return nil, "parse_error"
    end
    return data.choices[1].message and data.choices[1].message.content, nil
end

local function CallAI_Raw(messages)
    if Cfg.Provider == "gemini" then
        return CallGemini(messages)
    else
        return CallGroq(messages)
    end
end

