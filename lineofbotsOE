local function Trim(s)
    return (s:match("^%s*(.-)%s*$") or s)
end

local function IsFiltered(text)
    return text and #text > 0 and text:match("^[#%s]+$") ~= nil
end

local function IsAllowed(name)
    if #Cfg.Whitelist > 0 then
        for _, w in ipairs(Cfg.Whitelist) do
            if w:lower() == name:lower() then return true end
        end
        return false
    end
    for _, b in ipairs(Cfg.Blacklist) do
        if b:lower() == name:lower() then return false end
    end
    return true
end

local function GetNearby(radius)
    local result = {}
    local myHRP = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not myHRP then return result end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character then
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local dist = (myHRP.Position - hrp.Position).Magnitude
                if dist <= radius then
                    table.insert(result, {
                        name        = p.Name,
                        displayName = p.DisplayName,
                        distance    = math.round(dist),
                        userId      = p.UserId,
                    })
                end
            end
        end
    end
    return result
end

local function IsNearby(player, radius)
    local myHRP = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not myHRP or not player.Character then return false end
    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    return (myHRP.Position - hrp.Position).Magnitude <= radius
end

-- UTF-8 aware split (fix кириллица)
local function SafeSplit(text, maxLen)
    if #text <= maxLen then return {text} end
    local result = {}
    local i = 1
    while i <= #text do
        local chunk = text:sub(i, i + maxLen - 1)
        -- откат до границы UTF-8 символа
        while #chunk > 0 and chunk:byte(#chunk) >= 0x80 and chunk:byte(#chunk) < 0xC0 do
            chunk = chunk:sub(1, #chunk - 1)
        end
        if #chunk == 0 then chunk = text:sub(i, i + maxLen - 1) end
        table.insert(result, chunk)
        i = i + #chunk
    end
    return result
end

