local function loadSettings()
    pcall(function()
        if not readfile then return end
        local data
        local ok, result = pcall(readfile, LOB_SETTINGS_FILE)
        if ok and type(result) == "string" and result ~= "" then
            data = result:gsub("\r\n", "\n"):gsub("\r", "\n")
        else
            return
        end
        local cs = ClientSettings
        if not cs then return end
        local function getBool(key, default)
            local v = data:match(key .. "=(%a+)")
            if v == "true" then return true end
            if v == "false" then return false end
            return default
        end
        local function getNum(key, default)
            local v = data:match(key .. "=([%d%.]+)")
            return v and tonumber(v) or default
        end
        local function getStr(key, default)
            local v = data:match(key .. "=([^\n]+)")
            return v and v:match("^%s*(.-)%s*$") or default
        end
        cs.AutoReply       = getBool("AutoReply",       false)
        cs.MemoryEnabled   = getBool("MemoryEnabled",   true)
        cs.ActionsEnabled  = getBool("ActionsEnabled",  true)
        cs.WebSearch       = getBool("WebSearch",       false)
        cs.WorldReactions  = getBool("WorldReactions",  true)
        cs.AntiSpam        = getBool("AntiSpam",        true)
        cs.ReactToMention  = getBool("ReactToMention",  true)
        cs.PlayerAwareness = getBool("PlayerAwareness", true)
        cs.PlaceAwareness  = getBool("PlaceAwareness",  true)
        cs.CameraLook      = getBool("CameraLook",      true)
        cs.UsePlayerName   = getBool("UsePlayerName",   true)
        cs.FollowConfirm   = getBool("FollowConfirm",   true)
        cs.TokenEconomy    = getBool("TokenEconomy",    false)
        cs.PerUserMemory   = getBool("PerUserMemory",   false)
        cs.Temperature     = getNum("Temperature",      0.7)
        cs.MaxTokens       = getNum("MaxTokens",        1024)
        cs.StripHash       = getBool("StripHash",       true)
        cs.FollowingEnabled         = getBool("FollowingEnabled", true)
        cs.MaxHistory               = getNum("MaxHistory", 10)
        cs.CooldownSecondsPerUser   = getNum("CooldownSecondsPerUser", 0)
        cs.MaxMessagesPerSecond     = getNum("MaxMessagesPerSecond", 10)
        cs.MaxQueuePerUser          = getNum("MaxQueuePerUser", 10)
        if not cs.Range then cs.Range = {} end
        cs.Range.Enabled            = getBool("RangeEnabled", false)
        cs.Range.Studs              = getNum("RangeStuds", 50)
        cs.Range.Height             = getNum("RangeHeight", 0)
        cs.Range.IgnoreWalls        = getBool("RangeIgnoreWalls", false)
        cs.Range.ShowVisualizer     = getBool("RangeShowVisualizer", false)
        local pid = getStr("PersonalityId", "Friendly")
        if pid and pid ~= "" then cs.PersonalityId = pid end
    end)
end

