    mainBtn.AutoButtonColor = false
    mainBtn.BackgroundColor3 = THEME.SidebarSelected
    mainBtn.BackgroundTransparency = 0.5
    mainBtn.Size = UDim2.new(1, 0, 1, 0)
    mainBtn.Parent = holder
    makeCorner(mainBtn, 8)
    makeStroke(mainBtn, 1, THEME.Stroke, 0.6)

    mainBtn.MouseEnter:Connect(function() tween(mainBtn, TWEEN_FAST, { BackgroundColor3 = THEME.ButtonHover }) end)
    mainBtn.MouseLeave:Connect(function() tween(mainBtn, TWEEN_FAST, { BackgroundColor3 = THEME.Button }) end)

    local lbl = makeTextLabel(mainBtn, tostring(default), 14, "semibold")
    lbl.Size = UDim2.new(1, -34, 1, 0)
    lbl.Position = UDim2.new(0, 10, 0, 0)

    local arrow = Instance.new("ImageLabel")
    arrow.Name = "Chevron"
    arrow.Image = "rbxassetid://6031091004"
    arrow.ImageColor3 = THEME.TextDim
    arrow.ImageTransparency = 0.3
    arrow.BackgroundTransparency = 1
    arrow.Size = UDim2.new(0, 16, 0, 16)
    arrow.AnchorPoint = Vector2.new(1, 0.5)
    arrow.Position = UDim2.new(1, -10, 0.5, 0)
    arrow.Parent = mainBtn

    local isOpen = false
    local dropdownList = nil
    local overlay = nil
    local dropdownStroke = nil

    local function close()
        isOpen = false
        if dropdownList then
            local w = mainBtn.AbsoluteSize.X
            tween(dropdownList, TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Size = UDim2.fromOffset(w, 0), BackgroundTransparency = 1
            })
            if dropdownStroke then tween(dropdownStroke, TWEEN_FAST, { Transparency = 1 }) end
            for _, c in pairs(dropdownList:GetDescendants()) do
                if c:IsA("TextLabel") or c:IsA("TextButton") then tween(c, TWEEN_FAST, { TextTransparency = 1 }) end
            end
            task.delay(0.32, function() if dropdownList then dropdownList:Destroy() dropdownList = nil end end)
        end
        if overlay then overlay:Destroy() overlay = nil end
        mainBtn.ZIndex = 1
        tween(arrow, TWEEN_FAST, { Rotation = 0 })
    end

    mainBtn.MouseButton1Click:Connect(function()
        if isOpen then close() return end
        isOpen = true
        tween(arrow, TWEEN_FAST, { Rotation = 180 })

        local sg = holder:FindFirstAncestorWhichIsA("ScreenGui") or holder
        overlay = Instance.new("TextButton")
        overlay.Name = "DropdownOverlay"
        overlay.BackgroundTransparency = 1
        overlay.Text = ""
        overlay.Size = UDim2.new(1, 0, 1, 0)
        overlay.ZIndex = 250
        overlay.Parent = sg
        overlay.MouseButton1Click:Connect(close)
        mainBtn.ZIndex = 260

        local itemHeight = 36
        local maxVisible = 4
        local listHeight = math.min(#values, maxVisible) * itemHeight

        dropdownList = Instance.new("Frame")
        dropdownList.Size = UDim2.new(0, mainBtn.AbsoluteSize.X, 0, 0)
        dropdownList.Position = UDim2.fromOffset(mainBtn.AbsolutePosition.X, mainBtn.AbsolutePosition.Y + mainBtn.AbsoluteSize.Y + 4)
        dropdownList.BackgroundColor3 = Color3.fromRGB(24, 24, 27)
        dropdownList.BackgroundTransparency = 1
        dropdownList.ZIndex = 255
        dropdownList.ClipsDescendants = true
        dropdownList.Parent = sg
        makeCorner(dropdownList, 10)

        dropdownStroke = Instance.new("UIStroke")
        dropdownStroke.Color = Color3.fromRGB(51, 51, 51)
        dropdownStroke.Transparency = 1
        dropdownStroke.Thickness = 1
        dropdownStroke.Parent = dropdownList

        local scroll = Instance.new("ScrollingFrame")
        scroll.Size = UDim2.new(1, 0, 1, 0)
        scroll.BackgroundTransparency = 1
        scroll.ScrollBarThickness = 4
        scroll.ScrollBarImageColor3 = Color3.fromRGB(39, 39, 42)
        scroll.BorderSizePixel = 0
        scroll.Parent = dropdownList
        scroll.ZIndex = 256

        local layout = Instance.new("UIListLayout")
        layout.SortOrder = Enum.SortOrder.LayoutOrder
        layout.Padding = UDim.new(0, 0)
        layout.Parent = scroll
        layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y / _guiScale)
        end)

        for i, val in ipairs(values) do
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, 0, 0, itemHeight)
            btn.BackgroundColor3 = Color3.fromRGB(24, 24, 27)
            btn.BackgroundTransparency = 0
            btn.AutoButtonColor = false
            btn.Text = ""
            btn.LayoutOrder = i
            btn.Parent = scroll
            btn.ZIndex = 257
            local isSelected = (val == default)
            local label2 = Instance.new("TextLabel")
            label2.Text = tostring(val)
            label2.Font = Enum.Font.GothamMedium
            label2.TextSize = 14
            label2.TextXAlignment = Enum.TextXAlignment.Left
            label2.Size = UDim2.new(1, -40, 1, 0)
            label2.Position = UDim2.new(0, 12, 0, 0)
            label2.BackgroundTransparency = 1
            label2.TextColor3 = isSelected and THEME.Accent or Color3.fromRGB(161, 161, 170)
            label2.ZIndex = 258
            label2.Parent = btn
            if isSelected then
                local check = Instance.new("ImageLabel")
                check.Image = "rbxassetid://6031094667"
                check.ImageColor3 = THEME.Accent
                check.BackgroundTransparency = 1
                check.Size = UDim2.new(0, 16, 0, 16)
                check.Position = UDim2.new(1, -28, 0.5, -8)
                check.ZIndex = 258
                check.Parent = btn
            end
            btn.MouseEnter:Connect(function()
                tween(btn, TWEEN_FAST, { BackgroundColor3 = Color3.fromRGB(39, 39, 42) })
                tween(label2, TWEEN_FAST, { TextColor3 = Color3.fromRGB(255, 255, 255) })
            end)
            btn.MouseLeave:Connect(function()
                tween(btn, TWEEN_FAST, { BackgroundColor3 = Color3.fromRGB(24, 24, 27) })
                tween(label2, TWEEN_FAST, { TextColor3 = isSelected and THEME.Accent or Color3.fromRGB(161, 161, 170) })
            end)
            btn.MouseButton1Click:Connect(function()
                lbl.Text = tostring(val)
                default = val
                if callback then callback(val) end
                close()
            end)
        end

        tween(dropdownList, TweenInfo.new(0.38, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out), {
            Size = UDim2.fromOffset(mainBtn.AbsoluteSize.X - 2, listHeight),
            BackgroundTransparency = 0
        })
        tween(dropdownStroke, TWEEN_FAST, { Transparency = 0.5 })
    end)

    return {
        Frame = holder,
        Set = function(val) lbl.Text = tostring(val); default = val end,
    }
end

