local function doSpin(seconds)
    if not ClientSettings.ActionsEnabled then return end
    seconds = math.max(1, math.min(seconds or 3, 10))
    stopSpin()
    stopFollowing()
    local root = getLocalRootPart()
    if not root then return end
    _isSpinning = true
    _spinThread = task.spawn(function()
        local elapsed, dt = 0, 0.03
        while _isSpinning and elapsed < seconds do
            local ok = pcall(function()
                local r = getLocalRootPart()
                if not r then _isSpinning = false; return end
                r.CFrame = r.CFrame * CFrame.Angles(0, math.rad(360 * dt), 0)
            end)
            if not ok then break end
            elapsed = elapsed + dt
            task.wait(dt)
        end
        _isSpinning = false
        _spinThread  = nil
    end)
end

