local function toggleRow(parent, labelTxt, desc, initState, onChange)
    local row = newFrame(parent, C.BgCard, 1)
    row.Size          = UDim2.new(1, 0, 0, desc ~= "" and 38 or 26)
    row.AutomaticSize = Enum.AutomaticSize.None

    local lbl = newLabel(row, labelTxt, 12, Enum.Font.GothamMedium, C.Text)
    lbl.Size     = UDim2.new(1, -52, 0, 16)
    lbl.Position = UDim2.new(0, 0, 0, 2)

    if desc ~= "" then
        local dsc = newLabel(row, desc, 10, Enum.Font.Gotham, C.TextDim)
        dsc.Size     = UDim2.new(1, -52, 0, 13)
        dsc.Position = UDim2.new(0, 0, 0, 20)
    end

    local state = initState == true
    local pill = newFrame(row, state and C.Accent or C.BgInput)
    pill.Size     = UDim2.new(0, 38, 0, 20)
    pill.Position = UDim2.new(1, -38, 0.5, -10)
    newCorner(pill, 10)
    newStroke(pill, 1, state and C.StrokeAcc or C.Stroke, 0)

    local knob = newFrame(pill, C.White)
    knob.Size     = UDim2.new(0, 14, 0, 14)
    knob.Position = UDim2.new(0, state and 21 or 3, 0.5, -7)
    newCorner(knob, 7)

    local function setState(on, silent)
        state = on
        tw(pill, TI.fast, {BackgroundColor3 = on and C.Accent or C.BgInput})
        tw(knob, TI.fast, {Position = UDim2.new(0, on and 21 or 3, 0.5, -7)})
        pill.UIStroke.Color = on and C.StrokeAcc or C.Stroke
        if not silent and onChange then
            pcall(onChange, on)
        end
    end

    pill.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            setState(not state)
        end
    end)
    row.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            setState(not state)
        end
    end)

    return row, setState
end

local function sliderRow(parent, labelTxt, minV, maxV, initV, fmt, onChange)
    local row = newFrame(parent, C.BgCard, 1)
    row.Size = UDim2.new(1, 0, 0, 46)

    local lbl = newLabel(row, labelTxt, 12, Enum.Font.GothamMedium, C.Text)
    lbl.Size     = UDim2.new(0.65, 0, 0, 16)
    lbl.Position = UDim2.new(0, 0, 0, 0)

    local fmt2 = fmt or function(v) return tostring(v) end
    local valLbl = newLabel(row, fmt2(initV), 11, Enum.Font.Code, C.Accent)
    valLbl.Size     = UDim2.new(0.34, 0, 0, 16)
    valLbl.Position = UDim2.new(0.66, 0, 0, 0)
    valLbl.TextXAlignment = Enum.TextXAlignment.Right

    local track = newFrame(row, C.BgInput)
    track.Size     = UDim2.new(1, 0, 0, 5)
    track.Position = UDim2.new(0, 0, 0, 32)
    newCorner(track, 3)

    local pct0 = math.clamp((initV-minV)/(maxV-minV), 0, 1)
    local fill = newFrame(track, C.Accent)
    fill.Size     = UDim2.new(pct0, 0, 1, 0)
    newCorner(fill, 3)
    newGradient(fill, C.Accent, C.AccentB, 90)

    local handle = newFrame(track, C.White)
    handle.Size     = UDim2.new(0, 14, 0, 14)
    handle.Position = UDim2.new(pct0, -7, 0.5, -7)
    newCorner(handle, 7)
    newStroke(handle, 1.5, C.Accent, 0)

    local dragging = false
    local function update(mx)
        local abs = track.AbsolutePosition
        local wid = track.AbsoluteSize.X
        if wid <= 0 then return end
        local p   = math.clamp((mx - abs.X) / wid, 0, 1)
        local val = math.floor(minV + p*(maxV-minV) + 0.5)
        local realP = (val-minV)/(maxV-minV)
        fill.Size      = UDim2.new(realP, 0, 1, 0)
        handle.Position = UDim2.new(realP, -7, 0.5, -7)
        valLbl.Text    = fmt2(val)
        if onChange then pcall(onChange, val) end
    end
    track.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
