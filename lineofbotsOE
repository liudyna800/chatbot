local function handleTextChatService(textChatMessage)
    if not textChatMessage then return end
    local textSource = textChatMessage.TextSource
    if not textSource then return end
    if textSource.UserId == Players.LocalPlayer.UserId then return end
    local chatPlayer = Players:GetPlayerByUserId(textSource.UserId)
    if not chatPlayer then return end
    local msg = textChatMessage.Text
    if type(msg) ~= "string" or msg == "" then return end
    msg = msg:gsub("<font[^>]*>", ""):gsub("</font>", "")
           :gsub("<b>", ""):gsub("</b>", "")
           :gsub("<i>", ""):gsub("</i>", "")
           :gsub("<u>", ""):gsub("</u>", "")
           :gsub("<s>", ""):gsub("</s>", "")
    processChatMessage(chatPlayer, msg)
end

