local function getModel(settings)
    local explicit = settings.Models and settings.Models.groq
    if type(explicit) == "string" then
        explicit = explicit:match("^%s*(.-)%s*$")
        if explicit ~= "" then return explicit end
    end
    local pid = settings.PersonalityId
    if type(pid) == "string" and Personalities[pid] and Personalities[pid].model then
        return Personalities[pid].model
    end
    return "llama-3.1-8b-instant"
end

local function isBlacklisted(settings, userId)
    local bl = settings.Blacklist
    if type(bl) == "table" then
        local perm = bl.Permanent
        if type(perm) == "table" then
            if perm[userId] == true then return true end
            for _, id in ipairs(perm) do if id == userId then return true end end
        end
        local tmp = bl.Temporary
        if type(tmp) == "table" then
            local exp = tmp[userId]
            if type(exp) == "number" then
                if os.time() < exp then return true else tmp[userId] = nil end
            end
        end
    end
    local list = settings.BlacklistUserIds
    if type(list) ~= "table" then return false end
    for _, id in ipairs(list) do if id == userId then return true end end
    return false
end

local function passesTrigger(settings, message)
    if not message then return false end
    local trigger = settings.Trigger
    if type(trigger) ~= "table" then return true end
    local mode = trigger.Mode
    if mode == "all" then return true end
    local prefix = trigger.Prefix
    if type(prefix) ~= "string" or prefix == "" then return true end
    return string.sub(message:lower(), 1, #prefix) == prefix:lower()
end

local function stripTrigger(settings, message)
    local trigger = settings.Trigger
    if type(trigger) ~= "table" then return message end
    local mode = trigger.Mode
    if mode ~= "prefix" then return message end
    local prefix = trigger.Prefix
    if type(prefix) ~= "string" or prefix == "" then return message end
    if string.sub(message:lower(), 1, #prefix) == prefix:lower() then
        return string.sub(message, #prefix + 1)
    end
    return message
end

-- §SPLIT  (UTF-8 aware, no utf8 library needed)
local function charLen(s)
    local count = 0
    for i = 1, #s do
        local b = s:byte(i)
        if b < 0x80 or b >= 0xC0 then count = count + 1 end
    end
    return count
end

local function charOffset(s, n)
    local count = 0
    for i = 1, #s do
        local b = s:byte(i)
        if b < 0x80 or b >= 0xC0 then
            count = count + 1
            if count == n then return i end
        end
    end
    return #s + 1
end

local function splitTextIntoParts(text, maxLen)
    local parts = {}
    text   = text and text:match("^%s*(.-)%s*$") or ""
    if text == "" then return {""} end
    maxLen = math.max(maxLen or 200, 20)
    while charLen(text) > maxLen do
        local endByte = charOffset(text, maxLen + 1) - 1
        if endByte < 1 then endByte = #text end
        local head      = text:sub(1, endByte)
        local spacePos  = nil
        for i = #head, math.max(1, #head - 80), -1 do
            if head:sub(i, i) == " " then spacePos = i; break end
        end
        local part, rest
        if spacePos then
            part = head:sub(1, spacePos - 1)
            rest = text:sub(spacePos + 1)
        else
            part = head
            rest = text:sub(endByte + 1)
        end
        if part == "" then break end
        table.insert(parts, part)
        text = rest:match("^%s*(.-)%s*$") or ""
    end
    if charLen(text) > 0 then table.insert(parts, text) end
    return parts
end

local function sendBotMessage(text)
    if type(text) ~= "string" or text == "" then return end
    text = text:gsub("%[LANG:[^%]]*%]%s*", "")
    text = text:gsub("%[NAME:[^%]]*%]%s*", "")
    text = text:gsub("%[DO:[^%]]*%]%s*", "")
    text = text:gsub("%[SYSTEM:[^\n]*\n?", "")
    text = text:gsub("%[NEARBY[^%]]*%]%s*", "")
    text = text:gsub("%[DO:[%w_]*%s*", "")
    text = text:gsub("%[LANG:[%w_]*%s*", "")
    text = text:gsub("%[NAME:[^%s%]]*%s*", "")
    text = text:gsub("%[SYSTEM:[^%]]*", "")
    text = text:gsub("%[%s*%]", "")
    text = text:gsub("%[%s*$", "")
    text = text:gsub("^%s*%]%s*", "")
    text = normalizeOneLine(text)
    if text == "" then return end

    local maxLen = Constants.MaxResponseChars
    if charLen(text) <= maxLen then
        showBotChatMessage(text, true)
    else
        local parts = splitTextIntoParts(text, maxLen)
        for i, part in ipairs(parts) do
            if part ~= "" then
                showBotChatMessage(part, true)
                if i < #parts then task.wait(1.2) end
            end
        end
    end
end

