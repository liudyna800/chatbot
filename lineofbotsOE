local function lerpColor(a, b, t)
    return Color3.new(a.R+(b.R-a.R)*t, a.G+(b.G-a.G)*t, a.B+(b.B-a.B)*t)
end
local function getAuroraColor(palette, speed)
    local t = (os.clock() * (speed or 0.4)) % #palette
    local idx = math.floor(t) + 1
    return lerpColor(palette[idx], palette[(idx % #palette)+1], t-math.floor(t))
end

