-- Death reactions (event-based)
local _deathConns = {}

local function _watchPlayerDeath(p)
    local uid = p.UserId
    if _deathConns[uid] then
        pcall(function() _deathConns[uid]:Disconnect() end)
        _deathConns[uid] = nil
    end
    local char = p.Character
    if not char then return end
    local hum  = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    local lastPos   = nil
    local hrpForPos = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
    if hrpForPos then
        lastPos = hrpForPos.Position
        local alive = true
        task.spawn(function()
            while alive and _deathConns[uid] and p.Character == char do
                local r = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
                if r then lastPos = r.Position end
                local h2 = char:FindFirstChildOfClass("Humanoid")
                if not h2 or h2.Health <= 0 then break end
                task.wait(0.5)
            end
            alive = false
        end)
        p.CharacterAdded:Connect(function() alive = false end)
    end

    _deathConns[uid] = hum.Died:Connect(function()
        if not ClientSettings.WorldReactions or not ClientSettings.Enabled then return end
        local myChar = Players.LocalPlayer.Character
        local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
        if myRoot and lastPos then
            local radius = ClientSettings.Range.Enabled and ClientSettings.Range.Studs or 30
            if (lastPos - myRoot.Position).Magnitude > radius then return end
        end
        local name   = p.DisplayName or p.Name
        local msg    = "[SYSTEM: Player "..name.." just died near you. React in 1 short sentence, stay in character.]"
        local fakeId = uid + 10000000
        enqueueChatItem(fakeId, {
            player=p, userId=fakeId, name=p.Name,
            displayName=name, cleaned=msg,
            isWorld=true,
        })
        runChatQueue(fakeId)
    end)
end

