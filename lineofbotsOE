local function playAnimDirect(animId, duration)
    local humanoid = getLocalHumanoid()
    if not humanoid then return false end
    local char     = Players.LocalPlayer.Character
    if not char then return false end
    local animator = humanoid:FindFirstChildOfClass("Animator")
    if not animator then
        animator        = Instance.new("Animator")
        animator.Parent = humanoid
    end
    local anim     = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://" .. tostring(animId)
    anim.Parent    = humanoid
    local track
    local ok = pcall(function() track = animator:LoadAnimation(anim) end)
    pcall(function() anim.Parent = nil end)
    if not ok or not track then return false end
    for _, prio in ipairs({
        Enum.AnimationPriority.Action4, Enum.AnimationPriority.Action3,
        Enum.AnimationPriority.Action2, Enum.AnimationPriority.Action,
    }) do
        if pcall(function() track.Priority = prio end) then break end
    end
    pcall(function()
        for _, t in ipairs(animator:GetPlayingAnimationTracks()) do
            if t.Priority == Enum.AnimationPriority.Action
            or t.Priority == Enum.AnimationPriority.Action2
            or t.Priority == Enum.AnimationPriority.Action3
            or t.Priority == Enum.AnimationPriority.Action4 then
                t:Stop(0)
            end
        end
    end)
    track:Play(0, 1, 1)
    _activeEmoteTrack = track
    if duration then
        _activeEmoteThread = task.delay(duration, function()
            pcall(function() track:Stop(0.3) end)
            _activeEmoteTrack  = nil
            _activeEmoteThread = nil
            pcall(function()
                local char2   = Players.LocalPlayer.Character
                local animate = char2 and char2:FindFirstChild("Animate")
                local fn      = animate and animate:FindFirstChild("PlayEmote")
                if fn then fn:Invoke("idle") end
            end)
        end)
    end
    return true
end

