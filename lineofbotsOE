local RateLimiter = {}
RateLimiter.__index = RateLimiter

function RateLimiter.new(cooldownSeconds)
    return setmetatable({
        _cooldownSeconds = cooldownSeconds or 0,
        _lastAt          = {},
    }, RateLimiter)
end

function RateLimiter:setCooldown(cooldownSeconds)
    self._cooldownSeconds = cooldownSeconds or 0
end

function RateLimiter:allow(userId)
    local now  = os.clock()
    local last = self._lastAt[userId]
    if last and (now - last) < self._cooldownSeconds then return false end
    self._lastAt[userId] = now
    if (now - (self._lastClean or 0)) > 60 then
        self._lastClean = now
        local expiry = math.max(self._cooldownSeconds * 2, 30)
        for uid, t in pairs(self._lastAt) do
            if (now - t) > expiry then self._lastAt[uid] = nil end
        end
    end
    return true
end

