-- ══════════════════════════════════════════════════════
-- §DRAG  — перетаскивание окна
-- ══════════════════════════════════════════════════════
do
    local dragging  = false
    local dragStart = Vector2.zero
    local winStart  = Vector2.zero

    local function startDrag(inp)
        -- Не начинаем drag если кликнули на кнопки
        dragging  = true
        dragStart = Vector2.new(inp.Position.X, inp.Position.Y)
        local pos = win.Position
        winStart  = Vector2.new(pos.X.Offset, pos.Y.Offset)
    end

    header.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            -- Проверяем что не нажали на кнопки управления
            local rx = inp.Position.X - header.AbsolutePosition.X
            if rx < header.AbsoluteSize.X - 80 then
                startDrag(inp)
            end
        end
    end)

    UserInputService.InputChanged:Connect(function(inp)
        if not dragging then return end
        if inp.UserInputType ~= Enum.UserInputType.MouseMovement
        and inp.UserInputType ~= Enum.UserInputType.Touch then return end

        local delta = Vector2.new(inp.Position.X, inp.Position.Y) - dragStart
        local sz    = getScreenSize()

        -- Клампируем чтобы окно не уходило за экран
        local newX = math.clamp(winStart.X + delta.X, 0, sz.X - WIN_W)
        local newY = math.clamp(winStart.Y + delta.Y, 0, sz.Y - WIN_H)

        win.Position = UDim2.new(0, newX, 0, newY)
    end)

    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

