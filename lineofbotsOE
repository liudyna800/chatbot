        if not logoAccent or not logoAccent.Parent then return end
        _logoClock = _logoClock + dt
        local p = THEME.AuroraPalette or AURORA_COLORS
        local t = (_logoClock*(THEME.AuroraSpeed or 0.35)*1.2)%#p
        local i=math.floor(t)+1; local ni=(i%#p)+1; local f=t-math.floor(t)
        local a,b=p[i],p[ni]
        logoAccent.BackgroundColor3=Color3.new(a.R+(b.R-a.R)*f,a.G+(b.G-a.G)*f,a.B+(b.B-a.B)*f)
    end))

    local sidebarTitle = makeTextLabel(sidebarLogoArea, "LineOfBots", 17, "bold")
    sidebarTitle.TextColor3 = THEME.Text
    sidebarTitle.Position   = UDim2.new(0,22,0,14)
    sidebarTitle.Size       = UDim2.new(1,-24,0,20)

    local sidebarSubtitle = makeTextLabel(sidebarLogoArea, "v20.0.2", 10, "semibold")
    sidebarSubtitle.TextColor3 = THEME.TextDim
    sidebarSubtitle.Position   = UDim2.new(0,22,0,36)
    sidebarSubtitle.Size       = UDim2.new(1,-24,0,13)

    local titleDivider = Instance.new("Frame")
    titleDivider.Size = UDim2.new(1,-24,0,1)
    titleDivider.Position = UDim2.new(0,12,0,60)
    titleDivider.BackgroundColor3 = THEME.Stroke
    titleDivider.BackgroundTransparency = THEME.StrokeTransparency
    titleDivider.BorderSizePixel = 0
    titleDivider.Parent = sidebar

    local tabContainer = Instance.new("Frame")
    tabContainer.BackgroundTransparency = 1
    tabContainer.Position = UDim2.new(0,6,0,70)
    tabContainer.Size     = UDim2.new(1,-12,0,248)
    tabContainer.Parent   = sidebar
    local tabLayout = Instance.new("UIListLayout")
    tabLayout.Padding      = UDim.new(0,4)
    tabLayout.SortOrder    = Enum.SortOrder.LayoutOrder
    tabLayout.Parent       = tabContainer

    -- Sidebar status block
    local sidebarStatus = Instance.new("Frame")
    sidebarStatus.BackgroundColor3      = THEME.Card
    sidebarStatus.BackgroundTransparency = THEME.CardTransparency or 0.55
    sidebarStatus.BorderSizePixel       = 0
    sidebarStatus.AnchorPoint           = Vector2.new(0,1)
    sidebarStatus.Position              = UDim2.new(0,6,1,-10)
    sidebarStatus.Size                  = UDim2.new(1,-12,0,116)
    sidebarStatus.ClipsDescendants      = true
    sidebarStatus.Parent                = sidebar
    makeCorner(sidebarStatus, 18)
    makeStroke(sidebarStatus, 1, Color3.fromRGB(255,255,255), 0.82)
    local ssPad = Instance.new("UIPadding")
    ssPad.PaddingTop=UDim.new(0,7); ssPad.PaddingBottom=UDim.new(0,7)
    ssPad.PaddingLeft=UDim.new(0,10); ssPad.PaddingRight=UDim.new(0,6)
    ssPad.Parent = sidebarStatus
    local ssListLayout = Instance.new("UIListLayout")
    ssListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    ssListLayout.Padding   = UDim.new(0,2)
    ssListLayout.Parent    = sidebarStatus
    local ssTitle = makeTextLabel(sidebarStatus,"СОСТОЯНИЕ",8,"bold")
    ssTitle.Size = UDim2.new(1,0,0,12); ssTitle.TextColor3=THEME.TextDim; ssTitle.TextTransparency=0.4; ssTitle.LayoutOrder=0

    local function makeSsRow(lo)
        local row = Instance.new("Frame")
        row.BackgroundTransparency=1; row.Size=UDim2.new(1,0,0,18); row.LayoutOrder=lo; row.Parent=sidebarStatus
        local dot = Instance.new("Frame")
        dot.Size=UDim2.new(0,6,0,6); dot.AnchorPoint=Vector2.new(0,0.5); dot.Position=UDim2.new(0,0,0.5,0)
        dot.BackgroundColor3=Color3.fromRGB(80,80,100); dot.BorderSizePixel=0; dot.Parent=row
        makeCorner(dot, 999)
        local lbl = makeTextLabel(row,"...",10,"semibold")
        lbl.Size=UDim2.new(1,-10,1,0); lbl.Position=UDim2.new(0,10,0,0)
        lbl.TextColor3=THEME.TextDim; lbl.TextXAlignment=Enum.TextXAlignment.Left
        lbl.TextTruncate=Enum.TextTruncate.AtEnd; lbl.TextYAlignment=Enum.TextYAlignment.Center
        return dot, lbl
    end
    local dotApi,lblApi     = makeSsRow(1)
    local dotBot,lblBot     = makeSsRow(2)
    local dotPers,lblPers   = makeSsRow(3)
    local dotMem,lblMem     = makeSsRow(4)
    local dotModel,lblModel = makeSsRow(5)

    local function updateCtStatus()
        local s = ClientSettings
        local model = getModel and getModel(s) or ""
        local hasKey,apiName = false,"API"
        if model:find("^gemini") then
            local gk = s.ApiKeys and s.ApiKeys.gemini or ""
            hasKey = type(gk)=="string" and #gk>8; apiName="Gemini"
        else
            local gk = getGroqApiKey and getGroqApiKey() or ""
            hasKey = type(gk)=="string" and #gk>8 and gk:sub(1,4)=="gsk_"; apiName="Groq"
        end
        dotApi.BackgroundColor3 = hasKey and Color3.fromRGB(80,220,120) or Color3.fromRGB(220,80,80)
        lblApi.Text = hasKey and (apiName..": OK") or (apiName..": нет ключа")
        local on = s.Enabled and s.AutoReply
        dotBot.BackgroundColor3 = on and Color3.fromRGB(80,220,120) or Color3.fromRGB(220,80,80)
        lblBot.Text = on and "Бот: активен" or "Бот: выключен"
        dotPers.BackgroundColor3 = THEME.Accent
        lblPers.Text = tostring(s.PersonalityId or "—")
        local mem = s.MemoryEnabled
        dotMem.BackgroundColor3 = mem and Color3.fromRGB(100,160,255) or Color3.fromRGB(100,100,120)
        lblMem.Text = mem and "Память: вкл" or "Память: выкл"
        local mdl = getModel and getModel(s) or "?"
        local short = (mdl:match("[^/]+$") or mdl):sub(1,17)
        dotModel.BackgroundColor3 = Color3.fromRGB(160,100,255)
        lblModel.Text = short
    end
    task.spawn(function() while true do pcall(updateCtStatus) task.wait(3) end end)

    local currentTab      = "Основное"
    local isTabSwitching  = false
    local pendingTabName  = nil
    local tabButtons      = {}
    local tabFrames       = {}
    local tabSwitchId     = 0
    local tabFrameTweens  = {}

    local function updateTabIndicator(tabName, instant) end

    local function setTabButtonState(tabName, selected, instant)
        local btn = tabButtons[tabName]
        if not btn then return end
        local container = btn:FindFirstChild("ContentContainer")
        local strip  = btn:FindFirstChild("AccentStrip")
        local glowBg = btn:FindFirstChild("GlowBg")
        local icon   = container and container:FindFirstChild("Icon")  or btn:FindFirstChild("Icon")
        local label  = container and container:FindFirstChild("Label") or btn:FindFirstChild("Label")
        local bgTrans = selected and 0 or 1
        local bgCol   = selected and THEME.SidebarSelected or THEME.Sidebar
        local txtCol  = selected and THEME.Text   or THEME.TextDim
        local iconCol = selected and THEME.Accent or THEME.IconTint
        if strip then strip.Visible = selected; strip.BackgroundColor3 = THEME.Accent end
        if glowBg then
            if instant then glowBg.BackgroundTransparency = selected and 0.88 or 1
            else tween(glowBg, TWEEN_MED, {BackgroundTransparency = selected and 0.88 or 1}) end
        end
        if instant then
            btn.BackgroundTransparency=bgTrans; btn.BackgroundColor3=bgCol
            if label then label.TextColor3=txtCol end
            if icon  then icon.ImageColor3=iconCol end
        else
            tween(btn, TWEEN_MED, {BackgroundTransparency=bgTrans, BackgroundColor3=bgCol})
            if label then tween(label, TWEEN_MED, {TextColor3=txtCol}) end
            if icon  then tween(icon,  TWEEN_MED, {ImageColor3=iconCol}) end
        end
    end

    local contentArea = Instance.new("Frame")
    contentArea.BackgroundTransparency = 1
    contentArea.Position = UDim2.new(0, sidebarWidth, 0, 0)
    contentArea.Size     = UDim2.new(1, -sidebarWidth - contentAreaRightMargin, 1, 0)
    contentArea.ClipsDescendants = false
    contentArea.Parent   = window
    local contentPadValue = isMobile and 12 or 16
    local contentPad = Instance.new("UIPadding")
    contentPad.PaddingTop=UDim.new(0,contentPadValue); contentPad.PaddingBottom=UDim.new(0,contentPadValue)
    contentPad.PaddingLeft=UDim.new(0,contentPadValue); contentPad.PaddingRight=UDim.new(0,4)
    contentPad.Parent = contentArea

    local function cancelFrameTweens(frame)
        local arr = tabFrameTweens[frame]; if not arr then return end
        tabFrameTweens[frame] = nil
        for _,tw in ipairs(arr) do pcall(function() if tw and tw.PlaybackState==Enum.PlaybackState.Playing then tw:Cancel() end end) end
    end
    local function trackFrameTween(frame,tw)
        if not frame or not tw then return end
        tabFrameTweens[frame] = tabFrameTweens[frame] or {}
        table.insert(tabFrameTweens[frame], tw)
    end

    local function switchTab(name)
        if currentTab == name then return end
        if isTabSwitching then pendingTabName = name
            for n in pairs(tabButtons) do setTabButtonState(n, (n==name), false) end
            return
        end
        tabSwitchId = tabSwitchId + 1
        local switchId = tabSwitchId
        local oldTabName = currentTab
        local oldFrame   = tabFrames[oldTabName]
        local newFrame   = tabFrames[name]
        if not newFrame then return end
        currentTab = name
        for _, c in ipairs(gui:GetChildren()) do
            if c.Name=="DropdownOverlay" or c.Name=="DropdownList" then c:Destroy() end
        end
        for n in pairs(tabButtons) do setTabButtonState(n,(n==name),false) end
        updateTabIndicator(name,false)
        local basePos = UDim2.new(0,0,0,0)
        for _, frame in pairs(tabFrames) do
            if frame~=oldFrame and frame~=newFrame then
                cancelFrameTweens(frame)
                frame.Visible=false; frame.GroupTransparency=1; frame.Position=basePos
            end
        end
        isTabSwitching = true; pendingTabName = nil
        if oldFrame then
            cancelFrameTweens(oldFrame)
            oldFrame.Visible=true; oldFrame.Position=basePos; oldFrame.GroupTransparency=0
            local tOut = tween(oldFrame, TweenInfo.new(0.22,Enum.EasingStyle.Sine,Enum.EasingDirection.Out), {GroupTransparency=1})
            trackFrameTween(oldFrame, tOut)
        end
        if newFrame then
            cancelFrameTweens(newFrame)
            newFrame.GroupTransparency=1; newFrame.Position=UDim2.new(0.12,0,0,0); newFrame.Visible=true
            task.defer(function()
                local tIn = tween(newFrame, TweenInfo.new(0.45,Enum.EasingStyle.Quint,Enum.EasingDirection.Out), {GroupTransparency=0, Position=basePos})
                trackFrameTween(newFrame, tIn)
            end)
        end
        task.delay(TWEEN_TAB.Time+0.05, function()
            if tabSwitchId~=switchId then return end
            if oldFrame then oldFrame.Visible=false; oldFrame.Position=basePos; oldFrame.GroupTransparency=1 end
            if newFrame then newFrame.Visible=true; newFrame.GroupTransparency=0; newFrame.Position=basePos end
            isTabSwitching=false
            if pendingTabName and pendingTabName~=currentTab then
                local next=pendingTabName; pendingTabName=nil; switchTab(next)
            else pendingTabName=nil end
        end)
    end

    local function makeTabButton(name, iconId)
        local btn = Instance.new("TextButton")
        btn.Text=""; btn.Size=UDim2.new(1,0,0,38)
        btn.BackgroundTransparency=1; btn.BackgroundColor3=THEME.SidebarSelected
        btn.ClipsDescendants=true; btn.Parent=tabContainer
        makeCorner(btn, 18)
        local strip = Instance.new("Frame"); strip.Name="AccentStrip"
        strip.BackgroundColor3=THEME.Accent; strip.BorderSizePixel=0
        strip.Size=UDim2.new(0,3,0,22); strip.Position=UDim2.new(0,4,0.5,-11)
        strip.Visible=false; strip.Parent=btn; makeCorner(strip,2)
