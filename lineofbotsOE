-- Ловим фильтрацию наших сообщений
table.insert(Connections, TCS.MessageReceived:Connect(function(msg)
    local src = msg.TextSource
    if not src or src.UserId ~= LP.UserId then return end
    if IsFiltered(msg.Text) and LastSentMsg ~= "" then
        warn("[LOB] Сообщение было отфильтровано: " .. LastSentMsg)
        -- добавляем заметку в историю чтобы AI знал
        table.insert(History, {role = "user", content = string.format('[SYSTEM]: Твоё последнее сообщение "%s" было заблокировано Roblox фильтром (показалось как ####). Используй другие слова.', LastSentMsg)})
        table.insert(History, {role = "assistant", content = "Понял, буду использовать более чистые слова."})
        while #History > Cfg.HistoryMax * 2 do table.remove(History, 1) end
        SaveMemory()
        LastSentMsg = ""
    end
end))

-- Основной слушатель
table.insert(Connections, TCS.MessageReceived:Connect(function(msg)
    local src = msg.TextSource
    if not src then return end
    local sender = Players:GetPlayerByUserId(src.UserId)
    if not sender or sender == LP then return end

    local text = msg.Text
    if not text or text == "" then return end
    if IsFiltered(text) then return end

    if not Cfg.Enabled then return end
    if not IsAllowed(sender.Name) then return end

    local now = tick()
    local lastTime = PlayerCooldowns[sender.UserId] or 0
    if now - lastTime < Cfg.Cooldown then return end

    -- Proximity check
    if not Cfg.RespondToAll and not IsNearby(sender, Cfg.ProximityRadius) then return end

    -- Name-only mode
    if Cfg.RespondToName then
        if not text:lower():find(Cfg.BotName:lower(), 1, true) then return end
    end

    PlayerCooldowns[sender.UserId] = now
    Enqueue(text, sender.Name, sender.UserId)
end))

