-- =============================================
-- CALLBACK античита: буферизация → одно сообщение на игрока
-- =============================================
local detectBuffer = {}  -- detectBuffer[userId] = {cheats = {}, timer = nil}

local function flushDetect(player)
    local uid = player.UserId
    local buf = detectBuffer[uid]
    if not buf or #buf.cheats == 0 then return end

    -- DisplayName и username
    local displayName = player.DisplayName or player.Name
    local userName = player.Name
    local fullName = displayName .. " (@" .. userName .. ")"

    -- Собираем все типы читов в одну строку
    local cheatTypes = {}
    local details = {}
    local speedVal = nil
    for _, c in ipairs(buf.cheats) do
        table.insert(cheatTypes, c.cheatType)
        table.insert(details, c.reasonText)
        if c.speed then speedVal = c.speed end
    end
    local typesStr = table.concat(cheatTypes, " + ")
    local detailsStr = table.concat(details, "; ")

    -- Системный алерт — один (показываем displayName + @username)
    local alertText = "Детект [" .. typesStr .. "]: " .. fullName
    if speedVal then alertText = alertText .. " | скорость " .. speedVal end
    addChatMsgGlobal(alertText, false, true, userName)

    -- Память
    local memFact = os.date("%H:%M") .. " — " .. fullName .. " пойман (" .. detailsStr .. ")"
    addMemory(memFact)

    -- Промпт с чётким форматом: DisplayName (@username)
    local prompt = "Сообщи о читере. Игрок: " .. fullName .. ". Нарушения: " .. detailsStr
        .. ". ФОРМАТ СТРОГО: player (" .. fullName .. ") [" .. typesStr .. "] — причина одним предложением."
    askAIAnticheat(prompt,
        function(reply)
            aiProviderLabel.Text = currentProvider == "gemini" and "Провайдер: Gemini" or "Провайдер: Groq"
            addChatMsgGlobal(reply, true)
            clearMemBtn.Text = "Очистить память ИИ (" .. #aiMemory .. " фактов)"
        end,
        function(statusText, color)
            aiProviderLabel.Text = statusText
            aiProviderLabel.TextColor3 = color
        end
    )

    detectBuffer[uid] = nil
end

onCheatDetected = function(player, speed, reason)
    local speedRounded = speed > 0 and math.floor(speed * 10) / 10 or nil
    local reasonText = ""
    local cheatType = ""
    if reason == "SPEED_OVER_MAX" then
        reasonText = "скорость " .. speedRounded .. " (выше максимума 21.5)"
        cheatType = "СПИДХАК"
    elseif reason == "SPEED_SUSTAINED" then
        reasonText = "скорость " .. speedRounded .. " держится более 5 сек"
        cheatType = "СПИДХАК"
    elseif reason == "FLY" then
        reasonText = "флай (в воздухе более 3 сек без прыжка/падения)"
        cheatType = "ФЛАЙ"
        speedRounded = nil
    end

    local uid = player.UserId
    if not detectBuffer[uid] then
        detectBuffer[uid] = {cheats = {}}
    end
    -- Добавляем в буфер только уникальный тип
    local alreadyHas = false
    for _, c in ipairs(detectBuffer[uid].cheats) do
        if c.cheatType == cheatType then alreadyHas = true; break end
    end
    if not alreadyHas then
        table.insert(detectBuffer[uid].cheats, {
            cheatType = cheatType,
            reasonText = reasonText,
            speed = speedRounded
        })
    end

    -- Сбрасываем таймер — ждём 1 сек чтобы собрать все детекты на игрока
    if detectBuffer[uid].thread then
        task.cancel(detectBuffer[uid].thread)
    end
    detectBuffer[uid].thread = task.delay(1, function()
        flushDetect(player)
    end)
end



