-- ВАЖНО: объявляем ВСЕ флаги ДО функций которые их используют
local _isFollowing  = false
local _isGoing      = false   -- ← объявлен ЗДЕСЬ, до stopFollowing
local _followTarget = nil
local _followThread = nil

local function stopFollowing()
    _isFollowing  = false
    _isGoing      = false
    _followTarget = nil
    if _followThread then
        pcall(task.cancel, _followThread)
        _followThread = nil
    end
end

-- Pathfinding-шаг к позиции
-- followMode=true → прерываем цикл если _isFollowing стал false
-- followMode=false → прерываем цикл если _isGoing стал false
local function moveToPosition(targetPos, followMode)
    local humanoid = getLocalHumanoid()
    local root     = getLocalRootPart()
    if not humanoid or not root then return end

    local dist = (root.Position - targetPos).Magnitude
    if dist < 4 then return end

    local PathfindingService = game:GetService("PathfindingService")
    local ok = pcall(function()
        local path = PathfindingService:CreatePath({ AgentRadius = 2, AgentHeight = 5 })
        path:ComputeAsync(root.Position, targetPos)
        if path.Status == Enum.PathStatus.Success then
            for _, wp in ipairs(path:GetWaypoints()) do
                if followMode and not _isFollowing then break end
                if not followMode and not _isGoing then break end
                if wp.Action == Enum.PathWaypointAction.Jump then
                    humanoid.Jump = true
                end
                humanoid:MoveTo(wp.Position)
                local finished = humanoid.MoveToFinished:Wait(3)
                if not finished then break end
            end
        else
            humanoid:MoveTo(targetPos)
            humanoid.MoveToFinished:Wait(3)
        end
    end)
    if not ok then
        pcall(function()
            humanoid:MoveTo(targetPos)
            humanoid.MoveToFinished:Wait(3)
        end)
    end
end

-- [DO:goto] — подойти ОДИН РАЗ к игроку и остановиться
local function gotoPlayer(targetPlayer)
    if not ClientSettings.ActionsEnabled then return end
    if not targetPlayer then return end

    -- Останавливаем предыдущее следование
    stopFollowing()
    -- Ставим флаг ПОСЛЕ stopFollowing (stopFollowing сбрасывает _isGoing в false)
    _isGoing = true

    task.spawn(function()
        local char = targetPlayer.Character
        local targetRoot = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
        if not targetRoot then
            _isGoing = false
            return
        end
        moveToPosition(targetRoot.Position, false)
        _isGoing = false
    end)
end

-- [DO:follow] — бесконечно следовать за игроком
local function startFollowingPlayer(targetPlayer)
    if not ClientSettings.ActionsEnabled then return end
    stopFollowing()
    -- Ставим флаги ПОСЛЕ stopFollowing
    _isGoing     = false
    _isFollowing = true
    _followTarget = targetPlayer

    _followThread = task.spawn(function()
        while _isFollowing do
            local char = _followTarget and _followTarget.Character
            local targetRoot = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
            if targetRoot then
                moveToPosition(targetRoot.Position, true)
            end
            task.wait(0.3)
        end
    end)
end

-- ── ПРЫЖКИ ───────────────────────────────────────────────────────────────
local _isJumping        = false
local _jumpTimeoutThread = nil  -- аварийный таймаут сброса флага

-- Гарантированный сброс флага (через таймаут или по завершении)
local function _clearJumpFlag()
    _isJumping = false
    if _jumpTimeoutThread then
        pcall(task.cancel, _jumpTimeoutThread)
        _jumpTimeoutThread = nil
    end
end

local function doJump(count)
    if not ClientSettings.ActionsEnabled then return end
    if _isJumping then return end
    count = math.max(1, math.min(count or 1, 10))

    _isJumping = true
    -- Аварийный таймаут: через 15 сек флаг сбросится в любом случае
    _jumpTimeoutThread = task.delay(15, _clearJumpFlag)

    task.spawn(function()
        for i = 1, count do
            -- Каждая операция обёрнута в pcall отдельно — yield-safe
            local humanoid = getLocalHumanoid()
            if not humanoid then break end

            -- Проверяем стейт (без yield, безопасно)
            local inAir = false
            pcall(function()
                local s = humanoid:GetState()
                inAir = (s == Enum.HumanoidStateType.Jumping
                      or s == Enum.HumanoidStateType.FreeFalling
                      or s == Enum.HumanoidStateType.FallingDown)
            end)

            -- Если в воздухе — ждём приземления (yield внутри task.wait, не xpcall)
            if inAir then
                local landed = false
                local conn
                pcall(function()
                    conn = humanoid.StateChanged:Connect(function(_, ns)
                        if ns == Enum.HumanoidStateType.Landed
                        or ns == Enum.HumanoidStateType.Running
                        or ns == Enum.HumanoidStateType.GettingUp then
                            landed = true
                        end
                    end)
                end)
                local t0 = os.clock()
                while not landed and (os.clock() - t0) < 2.5 do
                    task.wait(0.05)
                end
                if conn then pcall(function() conn:Disconnect() end) end
                task.wait(0.05)
            end

            -- Прыгаем
            pcall(function()
                local h = getLocalHumanoid()
                if h then h.Jump = true end
            end)

            -- Пауза между прыжками (не после последнего)
            if i < count then
                task.wait(0.2)
            end
        end
        _clearJumpFlag()  -- нормальное завершение
    end)
end

-- ── СПИН (кружение) ───────────────────────────────────────────────────────
-- [DO:spin] — бот кружится на месте от 1 до 10 секунд
local _isSpinning = false
local _spinThread  = nil

local function stopSpin()
    _isSpinning = false
    if _spinThread then
        pcall(task.cancel, _spinThread)
        _spinThread = nil
    end
end

-- seconds = 1..10, скорость поворота = 360°/сек
local function doSpin(seconds)
    if not ClientSettings.ActionsEnabled then return end
    seconds = math.max(1, math.min(seconds or 3, 10))
    stopSpin()
    stopFollowing()  -- останавливаем ходьбу

    local root = getLocalRootPart()
    if not root then return end

    _isSpinning = true
    _spinThread = task.spawn(function()
        local elapsed = 0
        local dt = 0.03  -- ~33 fps
        while _isSpinning and elapsed < seconds do
            local r = root.CFrame
            root.CFrame = r * CFrame.Angles(0, math.rad(360 * dt), 0)
            elapsed = elapsed + dt
            task.wait(dt)
        end
        _isSpinning = false
        _spinThread = nil
    end)
end

