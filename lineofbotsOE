-- ═══════════════════════════════════════════════════════════
-- MAIN AI RESPONSE
-- ═══════════════════════════════════════════════════════════
local function Respond(text, senderName, senderId, sendToChat)
    -- billboard статус
    UpdateBillboard("💭 думаю...")

    -- думаю-сообщение
    if sendToChat and Cfg.ThinkMsg then
        SendChat("думаю...")
        task.wait(0.3)
    end

    -- аватар в фоне
    local avatarNote = nil
    if Cfg.VisionEnabled and senderId then
        avatarNote = AvatarCache[senderId]
        if not avatarNote then
            task.spawn(function()
                DescribeAvatar(senderId, senderName)
            end)
        end
    end

    -- строим сообщения
    local nearby = GetNearby(Cfg.ProximityRadius)
    local msgs = BuildMessages(text, senderName, nearby, avatarNote)

    -- вызов API
    local content, err = CallAI_Raw(msgs)

    if not content or Trim(content) == "" then
        warn("[LOB] Нет ответа от AI: " .. tostring(err))
        UpdateBillboard("🤖 " .. Cfg.BotName)
        return nil
    end

    -- парсим
    local clean, actions = ParseAI(content)

    -- сохраняем в историю
    table.insert(History, {role = "user",      content = string.format("[%s]: %s", senderName, text)})
    table.insert(History, {role = "assistant", content = content})
    while #History > Cfg.HistoryMax * 2 do table.remove(History, 1) end
    SaveMemory()

    -- отправляем
    if sendToChat then
        for _, a in ipairs(actions) do
            PlayEmote(a)
            task.wait(0.1)
        end
        if clean ~= "" then
            SendChat(clean)
        end
    end

    UpdateBillboard("🤖 " .. Cfg.BotName)
    return clean
end

-- ═══════════════════════════════════════════════════════════
-- QUEUE PROCESSOR
-- ═══════════════════════════════════════════════════════════
local function ProcessQueue()
    if Processing or #MsgQueue == 0 then return end
    Processing = true
    local item = table.remove(MsgQueue, 1)
    task.spawn(function()
        Respond(item.text, item.senderName, item.senderId, true)
        Processing = false
        if #MsgQueue > 0 then
            task.defer(ProcessQueue)
        end
    end)
end

local function Enqueue(text, senderName, senderId)
    table.insert(MsgQueue, {text = text, senderName = senderName, senderId = senderId})
    ProcessQueue()
end

