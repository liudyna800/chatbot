-- Воспроизвести анимацию напрямую через AnimationTrack (R6 и R15)
local function playAnimDirect(animId, duration)
    local humanoid = getLocalHumanoid()
    if not humanoid then return false end

    local char = Players.LocalPlayer.Character
    if not char then return false end

    local animator = humanoid:FindFirstChildOfClass("Animator")
    if not animator then
        animator = Instance.new("Animator")
        animator.Parent = humanoid
    end

    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://" .. tostring(animId)
    anim.Parent = humanoid

    local track
    local ok = pcall(function()
        track = animator:LoadAnimation(anim)
    end)
    pcall(function() anim.Parent = nil end)

    if not ok or not track then return false end

    -- Максимальный приоритет
    for _, prio in ipairs({
        Enum.AnimationPriority.Action4,
        Enum.AnimationPriority.Action3,
        Enum.AnimationPriority.Action2,
        Enum.AnimationPriority.Action,
    }) do
        if pcall(function() track.Priority = prio end) then break end
    end

    -- Останавливаем все конкурирующие треки перед воспроизведением
    pcall(function()
        for _, t in ipairs(animator:GetPlayingAnimationTracks()) do
            t:Stop(0)
        end
    end)

    track:Play(0, 1, 1)
    _activeEmoteTrack = track

    if duration then
        _activeEmoteThread = task.delay(duration, function()
            pcall(function() track:Stop(0.1) end)
            _activeEmoteTrack = nil
            _activeEmoteThread = nil
        end)
    end

    return true
end

local function playEmote(emoteName, duration)
    if not ClientSettings.ActionsEnabled then return end
    local humanoid = getLocalHumanoid()
    if not humanoid then return end

    stopCurrentEmote()

    local rigType = getCharacterRigType()

    -- Маппинг всех эмоций на встроенные имена Roblox
    local builtinMap = {
        wave="wave", laugh="laugh", cheer="cheer", point="point",
        sit="sit", dance="dance1", dance2="dance2", dance3="dance3",
        hello="wave", hi="wave", bye="wave",
        shrug="wave", agree="cheer", disagree="point",
        yay="cheer", victory="cheer", stadium="cheer", charging="cheer",
        sorry="wave", sad="point", shy="wave", salute="wave",
        tilt="laugh", confused="point", dizzy="laugh",
        eyeroll="laugh", facepalm="laugh",
        robot="dance2", lol="laugh", haha="laugh",
    }
    local builtinName = builtinMap[emoteName]

    if rigType == "R6" then
        -- R6: правильный способ — Animate.PlayEmote:Invoke()
        -- humanoid:PlayEmote() и AnimationTrack на R6 не работают
        local char = Players.LocalPlayer.Character
        local animateScript = char and char:FindFirstChild("Animate")
        local playEmoteFn = animateScript and animateScript:FindFirstChild("PlayEmote")

        if playEmoteFn and builtinName then
            local ok = pcall(function()
                playEmoteFn:Invoke(builtinName)
            end)
            if ok then
                if duration then
                    _activeEmoteThread = task.delay(duration, function()
                        -- Возврат в idle через Animate скрипт
                        local animateNow = Players.LocalPlayer.Character
                            and Players.LocalPlayer.Character:FindFirstChild("Animate")
                        local fn = animateNow and animateNow:FindFirstChild("PlayEmote")
                        if fn then pcall(function() fn:Invoke("idle") end) end
                        -- Дополнительно останавливаем все Action треки
                        local hum = getLocalHumanoid()
                        local animator = hum and hum:FindFirstChildOfClass("Animator")
                        if animator then
                            pcall(function()
                                for _, t in ipairs(animator:GetPlayingAnimationTracks()) do
                                    if t.Priority == Enum.AnimationPriority.Action
                                    or t.Priority == Enum.AnimationPriority.Action2 then
                                        t:Stop(0.3)
                                    end
                                end
                            end)
                        end
                        _activeEmoteThread = nil
                    end)
                end
                return
            end
        end

        -- Фоллбэк: AnimationTrack с правильными R6 ID
        local animId = R6_ANIM_IDS[emoteName]
        if animId then playAnimDirect(animId, duration) end
        return
    end

    -- R15: humanoid:PlayEmote() работает для встроенных
    if builtinName then
        local ok, played = pcall(function()
            return humanoid:PlayEmote(builtinName)
        end)
        if ok and played then
            if duration then
                _activeEmoteThread = task.delay(duration, function()
                    -- Правильная остановка R15 анимации через Animator
                    local animator = humanoid:FindFirstChildOfClass("Animator")
                    if animator then
                        pcall(function()
                            for _, t in ipairs(animator:GetPlayingAnimationTracks()) do
                                if t.Priority == Enum.AnimationPriority.Action
                                or t.Priority == Enum.AnimationPriority.Action2
                                or t.Priority == Enum.AnimationPriority.Action3
                                or t.Priority == Enum.AnimationPriority.Action4 then
                                    t:Stop(0.3)
                                end
                            end
                        end)
                    end
                    _activeEmoteThread = nil
                end)
            end
            return
        end
    end

    -- R15 фоллбэк: AnimationTrack
    local animId = R15_ANIM_IDS[emoteName]
    if animId then playAnimDirect(animId, duration) end
end

