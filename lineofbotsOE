-- HTTP HELPER
-- ═══════════════════════════════════════════════════════════
local function DoRequest(url, method, headers, body)
    local fn = request or (syn and syn.request) or http_request or (http and http.request)
    if not fn then warn("[LOB] No HTTP function!") return nil end
    local ok, res = pcall(fn, {
        Url = url,
        Method = method or "GET",
        Headers = headers or {},
        Body = body or "",
    })
    if not ok then warn("[LOB] Request error: " .. tostring(res)) return nil end
    return res
end

