-- Тогл-ряд
local function makeToggleRow(parent, labelTxt, desc, initState, onChange)
    local row = frame(parent, T.BgBase, 1)
    row.Size         = UDim2.new(1, 0, 0, 0)
    row.AutomaticSize = Enum.AutomaticSize.Y

    local lbl = label(row, labelTxt, 13, T.Sans, T.Text)
    lbl.Size     = UDim2.new(1, -52, 0, 18)
    lbl.Position = UDim2.new(0, 0, 0, 0)

    if desc and desc ~= "" then
        local dsc = label(row, desc, 11, T.Sans, T.TextDim)
        dsc.Size     = UDim2.new(1, -52, 0, 14)
        dsc.Position = UDim2.new(0, 0, 0, 20)
        row.Size = UDim2.new(1, 0, 0, 38)
    else
        row.Size = UDim2.new(1, 0, 0, 22)
    end

    -- Toggle pill
    local state = initState == true
    local pill = frame(row, state and T.Accent or T.BgInput)
    pill.Size     = UDim2.new(0, 40, 0, 20)
    pill.Position = UDim2.new(1, -40, 0.5, -10)
    corner(pill, 10)
    stroke(pill, 1, state and T.Accent or T.StrokeHard, state and 0.6 or 0)

    local knob = frame(pill, Color3.fromRGB(255,255,255))
    knob.Size     = UDim2.new(0, 14, 0, 14)
    knob.Position = UDim2.new(0, state and 23 or 3, 0.5, -7)
    corner(knob, 7)

    local function setState(on, silent)
        state = on
        tw(pill, tw_fast, {
            BackgroundColor3 = on and T.Accent or T.BgInput,
        })
        tw(knob, tw_fast, {
            Position = UDim2.new(0, on and 23 or 3, 0.5, -7)
        })
        pill.UIStroke.Color = on and T.Accent or T.StrokeHard
        pill.UIStroke.Transparency = on and 0.6 or 0
        if not silent and onChange then onChange(on) end
    end

    pill.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            setState(not state)
        end
    end)

    return row, setState
end

