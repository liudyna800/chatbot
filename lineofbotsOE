    lbl.Size     = UDim2.new(1, -38, 1, 0)
    lbl.Position = UDim2.new(0, 36, 0, 0)

    tabBtns[id] = {btn=btn, lbl=lbl, ico=icoLbl, bar=bar}

    btn.MouseEnter:Connect(function()
        if activeTab ~= id then
            tw(btn, TI.fast, {BackgroundTransparency=0.6, BackgroundColor3=C.BgHover})
            tw(lbl, TI.fast, {TextColor3=C.Text})
        end
    end)
    btn.MouseLeave:Connect(function()
        if activeTab ~= id then
            tw(btn, TI.fast, {BackgroundTransparency=1})
            tw(lbl, TI.fast, {TextColor3=C.TextMid})
        end
    end)
    btn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1
        or inp.UserInputType == Enum.UserInputType.Touch then
            switchTab(id)
        end
    end)
end

