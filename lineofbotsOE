    local lblEl = label(row, lbl2, 13, T.Sans, T.Text)
    lblEl.Size     = UDim2.new(0.6, 0, 0, 16)
    lblEl.Position = UDim2.new(0, 0, 0, 0)

    local valLbl = label(row, tostring(initV), 12, T.Mono, T.Accent)
    valLbl.Size     = UDim2.new(0.35, 0, 0, 16)
    valLbl.Position = UDim2.new(0.65, 0, 0, 0)
    valLbl.TextXAlignment = Enum.TextXAlignment.Right

    local track = frame(row, T.BgInput)
    track.Size     = UDim2.new(1, 0, 0, 6)
    track.Position = UDim2.new(0, 0, 0, 28)
    corner(track, 3)
    stroke(track, 1, T.StrokeSoft, 0)

    local fill = frame(track, T.Accent)
    fill.Size     = UDim2.new((initV - minV)/(maxV - minV), 0, 1, 0)
    fill.Position = UDim2.new(0, 0, 0, 0)
    corner(fill, 3)
    gradient(fill, T.Accent, T.Purple, 90)

    local knob2 = frame(track, Color3.fromRGB(255,255,255))
    knob2.Size     = UDim2.new(0, 14, 0, 14)
    knob2.Position = UDim2.new((initV - minV)/(maxV - minV), -7, 0.5, -7)
    corner(knob2, 7)
    stroke(knob2, 1.5, T.Accent, 0)

    local dragging2 = false
    local function updateSlider(mx)
        local abs = track.AbsolutePosition
        local wid = track.AbsoluteSize.X
        local pct = math.clamp((mx - abs.X) / wid, 0, 1)
        local val = math.floor(minV + pct * (maxV - minV) + 0.5)
        local p   = (val - minV) / (maxV - minV)
        fill.Size     = UDim2.new(p, 0, 1, 0)
        knob2.Position = UDim2.new(p, -7, 0.5, -7)
        valLbl.Text   = tostring(val)
        if onChange then onChange(val) end
    end

    track.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging2 = true
            updateSlider(inp.Position.X)
        end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if dragging2 and inp.UserInputType == Enum.UserInputType.MouseMovement then
            updateSlider(inp.Position.X)
        end
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging2 = false
        end
    end)

    return row
end

