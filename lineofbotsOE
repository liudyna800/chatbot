-- ═══════════════════════════════════════════════════════
local minimized = false
local savedPos  = main.Position

closeBtn.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        tw(main, tw_med, {Size=UDim2.new(0,0,0,0), Position=UDim2.new(0.5,0,0.5,0)})
        task.delay(0.3, function()
            screenGui:Destroy()
        end)
    end
end)

minBtn.InputBegan:Connect(function(inp)
    if inp.UserInputType == Enum.UserInputType.MouseButton1 then
        minimized = not minimized
        if minimized then
            savedPos = main.Position
            tw(main, tw_med, {Size=UDim2.new(0, WIN_W, 0, 48)})
            body.Visible = false
        else
            body.Visible = true
            tw(main, tw_med, {Size=UDim2.new(0, WIN_W, 0, WIN_H)})
        end
    end
end)

-- ═══════════════════════════════════════════════════════
-- §PRIME_HOTKEY  —  Toggle горячая клавиша (RightAlt)
-- ═══════════════════════════════════════════════════════
UserInputService.InputBegan:Connect(function(inp, gp)
    if gp then return end
    if inp.KeyCode == Enum.KeyCode.RightAlt then
        main.Visible = not main.Visible
    end
end)

