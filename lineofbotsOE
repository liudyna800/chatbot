-- §PRIME_HELPERS  —  базовые строительные блоки
-- ═══════════════════════════════════════════════════════
local tw_fast  = TweenInfo.new(0.15, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
local tw_med   = TweenInfo.new(0.28, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
local tw_slow  = TweenInfo.new(0.45, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)

local function tw(obj, info, props)
    TweenService:Create(obj, info, props):Play()
end

local function corner(p, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 8)
    c.Parent = p
    return c
end

local function stroke(p, thick, col, trans)
    local s = Instance.new("UIStroke")
    s.Thickness    = thick or 1
    s.Color        = col   or T.StrokeSoft
    s.Transparency = trans or 0
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = p
    return s
end

local function padding(p, all, lr, tb)
    local u = Instance.new("UIPadding")
    if all then
        u.PaddingTop    = UDim.new(0, all)
        u.PaddingBottom = UDim.new(0, all)
        u.PaddingLeft   = UDim.new(0, all)
        u.PaddingRight  = UDim.new(0, all)
    else
        local h = lr or 0
        local v = tb or 0
        u.PaddingLeft   = UDim.new(0, h)
        u.PaddingRight  = UDim.new(0, h)
        u.PaddingTop    = UDim.new(0, v)
        u.PaddingBottom = UDim.new(0, v)
    end
    u.Parent = p
    return u
end

local function listLayout(p, dir, pad, align)
    local l = Instance.new("UIListLayout")
    l.FillDirection     = dir   or Enum.FillDirection.Vertical
    l.Padding           = UDim.new(0, pad or 0)
    l.SortOrder         = Enum.SortOrder.LayoutOrder
    l.HorizontalAlignment = align or Enum.HorizontalAlignment.Left
    l.Parent = p
    return l
end

local function label(p, txt, sz, font, col)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    l.Text      = txt  or ""
    l.TextSize  = sz   or 13
    l.Font      = font or T.Sans
    l.TextColor3 = col or T.Text
    l.TextXAlignment = Enum.TextXAlignment.Left
    l.RichText  = false
    l.Parent    = p
    return l
end

local function frame(p, bg, bgt)
    local f = Instance.new("Frame")
    f.BackgroundColor3    = bg  or T.BgCard
    f.BackgroundTransparency = bgt or 0
    f.BorderSizePixel     = 0
    f.Parent = p
    return f
end

local function scrollFrame(p, bar)
    local s = Instance.new("ScrollingFrame")
    s.BackgroundTransparency = 1
    s.BorderSizePixel        = 0
    s.CanvasSize             = UDim2.new(0,0,0,0)
    s.ScrollBarThickness     = bar or 3
    s.ScrollBarImageColor3   = T.AccentDim
    s.ScrollBarImageTransparency = 0.4
    s.AutomaticCanvasSize    = Enum.AutomaticSize.Y
    s.Parent = p
    return s
end

-- Gradient overlay (декоративный)
local function gradient(p, c0, c1, rot)
    local g = Instance.new("UIGradient")
    g.Color    = ColorSequence.new(c0, c1)
    g.Rotation = rot or 90
    g.Parent   = p
    return g
end

