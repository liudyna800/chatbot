local function doJump(count)
    if not ClientSettings.ActionsEnabled then return end
    if _isJumping then return end
    count    = math.max(1, math.min(count or 1, 10))
    _isJumping = true
    _jumpTimeoutThread = task.delay(15, _clearJumpFlag)
    task.spawn(function()
        for i = 1, count do
            local humanoid = getLocalHumanoid()
            if not humanoid then break end
            local inAir = false
            pcall(function()
                local s = humanoid:GetState()
                inAir = (s == Enum.HumanoidStateType.Jumping
                      or s == Enum.HumanoidStateType.Freefall
                      or s == Enum.HumanoidStateType.FallingDown)
            end)
            if inAir then
                local landed, conn = false, nil
                pcall(function()
                    conn = humanoid.StateChanged:Connect(function(_, ns)
                        if ns == Enum.HumanoidStateType.Landed
                        or ns == Enum.HumanoidStateType.Running
                        or ns == Enum.HumanoidStateType.GettingUp then
                            landed = true
                        end
                    end)
                end)
                local t0 = os.clock()
                while not landed and (os.clock() - t0) < 2.5 do task.wait(0.05) end
                if conn then pcall(function() conn:Disconnect() end) end
                task.wait(0.05)
            end
            pcall(function()
                local h = getLocalHumanoid()
                if h then
                    h:ChangeState(Enum.HumanoidStateType.Jumping)
                    task.delay(0.05, function() if h and h.Parent then h.Jump = true end end)
                end
            end)
            if i < count then task.wait(0.8) end
        end
        _clearJumpFlag()
    end)
end

