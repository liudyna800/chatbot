            visualizerPart.Material=Enum.Material.SmoothPlastic; visualizerPart.Color=Color3.fromRGB(0,150,255); visualizerPart.Transparency=0.8
            visualizerPart.TopSurface=Enum.SurfaceType.Smooth; visualizerPart.BottomSurface=Enum.SurfaceType.Smooth
            local diam=ClientSettings.Range.Studs*2; local h=ClientSettings.Range.Height; local cylH=(h and h>0) and (h*2) or 0.4
            visualizerPart.Size=Vector3.new(cylH,diam,diam); visualizerPart.Parent=workspace
            local weld=Instance.new("Weld"); weld.Part0=root; weld.Part1=visualizerPart; weld.C0=CFrame.Angles(0,0,math.rad(90)); weld.Parent=visualizerPart
        else
            local diam=ClientSettings.Range.Studs*2; local h=ClientSettings.Range.Height; local cylH=(h and h>0) and (h*2) or 0.4
            visualizerPart.Size=Vector3.new(cylH,diam,diam)
        end
    end
    updateRangeVisualizer()

    -- Tab order and init
    local tabOrder={["Основное"]=1,["Поведение"]=2,["Восприятие"]=3,["Модерация"]=4,["Настройки"]=5,["Чат с ИИ"]=6}
    for name,btn in pairs(tabButtons) do btn.LayoutOrder=tabOrder[name] or 9 end

    task.defer(function()
        local basePos=UDim2.new(0,0,0,0)
        for _,frame in pairs(tabFrames) do frame.Visible=false; frame.GroupTransparency=1; frame.Position=basePos end
        if tabFrames[currentTab] then tabFrames[currentTab].Visible=true; tabFrames[currentTab].GroupTransparency=0 end
        for n in pairs(tabButtons) do setTabButtonState(n,(n==currentTab),true) end
        updateTabIndicator(currentTab,true)
    end)

    switchTab("Основное")

    -- Auto-check saved keys on startup
    task.spawn(function()
        task.wait(2)
        local savedKey=getGroqApiKey()
        if savedKey and savedKey:sub(1,4)=="gsk_" and #savedKey>8 then
            local req=(syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request
            if req then
                local ok2,res2=pcall(req,{Url="https://api.groq.com/openai/v1/chat/completions",Method="POST",
                    Headers={["Authorization"]="Bearer "..savedKey,["Content-Type"]="application/json"},
                    Body=HttpService:JSONEncode({model="llama-3.1-8b-instant",max_tokens=1,messages={{role="user",content="hi"}}})})
                if ok2 and res2 then parseRateLimitHeaders(res2.Headers or res2.headers or {}) end
            end
        end
    end)

    do
        local uis2=game:GetService("UserInputService"); local cam2=workspace.CurrentCamera
        local vp2=cam2 and cam2.ViewportSize or Vector2.new(0,0)
        print(string.format("[LineOfBots] viewport=%.0fx%.0f touch=%s keyboard=%s",vp2.X,vp2.Y,tostring(uis2.TouchEnabled),tostring(uis2.KeyboardEnabled)))
    end
end

createInterface()
