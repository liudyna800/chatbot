local function buildSystemPrompt()
    local memBlock = buildMemoryBlock()
    -- Снапшот также в системном промпте для контекста
    local playersBlock = #playersSnapshot > 0
        and ("\n\nИгроки онлайн (обновляется каждые 2 сек):\n" .. table.concat(playersSnapshot, "\n"))
        or "\n\nИгроков онлайн нет."

    local prompt = [[Ты AI-ассистент для игры Piggy Build Mode в Roblox. Помогаешь модератору.
Скорости: Piggy=13, выживший ходьба=15, бег=21 (норма до 5 сек).
Чит: скорость>21.5 сразу, или 15.5-21.5 держится >5 сек.
Когда сообщаешь о читере — пиши player (@никнейм), точную скорость, причину.
СТРОГО: НИКОГДА не выдумывай ники, скорости или события. Отвечай только по данным списка игроков и памяти детектов.
Если спросят про конкретного игрока — ищи его в списке онлайн и отвечай по реальным данным.
Если игрока нет в списке — скажи что он не найден онлайн.
Список нарушителей — только те у кого статус ЗАДЕТЕКТЕН или подозрение.
Отвечай КОРОТКО, 1-3 предложения.
Если просят запомнить — ответь "Запомнил: <факт>" в начале.]] .. playersBlock
    if memBlock ~= "" then
        prompt = prompt .. "\n\n" .. memBlock
    end
    return prompt
end

local chatHistory = {}

local function buildGeminiBody(userMsg)
    local contents = {}
    for _, m in ipairs(chatHistory) do
        table.insert(contents, {
            role = m.role == "assistant" and "model" or "user",
            parts = {{text = m.content}}
        })
    end
    table.insert(contents, {role = "user", parts = {{text = userMsg}}})
    return HttpService:JSONEncode({
        system_instruction = {parts = {{text = buildSystemPrompt()}}},
        contents = contents,
        generationConfig = {maxOutputTokens = 200, temperature = 0.7}
    })
end

local function buildGroqBody(userMsg)
    local messages = {{role = "system", content = buildSystemPrompt()}}
    for _, m in ipairs(chatHistory) do
        table.insert(messages, {role = m.role, content = m.content})
    end
    table.insert(messages, {role = "user", content = userMsg})
    return HttpService:JSONEncode({
        model = "openai/gpt-oss-120b",
        messages = messages,
        max_tokens = 200,
        temperature = 0.7
    })
end

local function callGemini(userMsg)
    local key = settings.geminiKey
    if key == "" then return nil, "no_key" end
    local url = "https://generativelanguage.googleapis.com/v1beta/models/gemini-3.1-flash-lite-preview:generateContent?key=" .. key
    local ok, res = pcall(function()
        return request({
            Url = url, Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = buildGeminiBody(userMsg)
        })
    end)
    if not ok then return nil, "error" end
    if res.StatusCode == 429 then return nil, "rate_limit" end
    if res.StatusCode ~= 200 then return nil, "error" end
    local data = HttpService:JSONDecode(res.Body)
    local text = data and data.candidates and data.candidates[1]
        and data.candidates[1].content and data.candidates[1].content.parts
        and data.candidates[1].content.parts[1] and data.candidates[1].content.parts[1].text
    return text, nil
end

local function callGroq(userMsg)
    local key = settings.groqKey
    if key == "" then return nil, "no_key" end
    local now = tick()
    if now - groqMinuteStart >= 60 then
        groqTokensUsed = 0; groqMinuteStart = now
    end
    while groqTokensUsed >= GROQ_LIMIT do
        local waitSec = 60 - (tick() - groqMinuteStart)
        if waitSec <= 0 then groqTokensUsed = 0; groqMinuteStart = tick(); break end
        setAiStatus("Groq лимит, жду " .. math.ceil(waitSec) .. "с...", Color3.fromRGB(255, 180, 0))
        task.wait(2)
        if tick() > geminiLimitUntil and currentProvider == "groq" then
            currentProvider = "gemini"
            return nil, "switch_to_gemini"
        end
    end
    local ok, res = pcall(function()
        return request({
            Url = "https://api.groq.com/openai/v1/chat/completions",
            Method = "POST",
            Headers = {["Content-Type"] = "application/json", ["Authorization"] = "Bearer " .. key},
            Body = buildGroqBody(userMsg)
        })
    end)
    if not ok then return nil, "error" end
    if res.StatusCode == 429 then groqTokensUsed = GROQ_LIMIT; return nil, "rate_limit" end
    if res.StatusCode ~= 200 then return nil, "error" end
    local data = HttpService:JSONDecode(res.Body)
    local text = data and data.choices and data.choices[1] and data.choices[1].message and data.choices[1].message.content
    if text then
        groqTokensUsed = groqTokensUsed + math.ceil(#text / 4) + math.ceil(#buildGroqBody(userMsg) / 4)
    end
    return text, nil
end

local aiWorking = false
local anticheatQueue = {}  -- очередь репортов античита

local function askAI(userMsg, onReply, onStatus)
    if aiWorking then return end
    aiWorking = true
    task.spawn(function()
        local reply = nil
        local attempt = 0
        while not reply and attempt < 10 do
            attempt = attempt + 1
            if currentProvider == "groq" and tick() > geminiLimitUntil then
                currentProvider = "gemini"
                onStatus("Gemini восстановлен", Color3.fromRGB(0, 200, 100))
                task.wait(0.3)
            end
            if currentProvider == "gemini" then
                onStatus("Думаю (Gemini)...", Color3.fromRGB(100, 180, 255))
                local text, err = callGemini(userMsg)
                if text then reply = text
                elseif err == "rate_limit" then
                    geminiLimitUntil = tick() + 65; currentProvider = "groq"
                    onStatus("Gemini лимит -> Groq", Color3.fromRGB(255, 180, 0)); task.wait(0.5)
                elseif err == "no_key" then
                    onStatus("Нет ключа Gemini!", Color3.fromRGB(255, 80, 80)); currentProvider = "groq"
                else onStatus("Ошибка Gemini", Color3.fromRGB(255, 80, 80)); task.wait(2) end
            elseif currentProvider == "groq" then
                onStatus("Думаю (Groq)...", Color3.fromRGB(180, 100, 255))
                local text, err = callGroq(userMsg)
                if text then reply = text
                elseif err == "switch_to_gemini" then currentProvider = "gemini"
                elseif err == "no_key" then
                    onStatus("Нет ключа Groq!", Color3.fromRGB(255, 80, 80)); task.wait(3); break
                elseif err ~= "rate_limit" then
                    onStatus("Ошибка Groq", Color3.fromRGB(255, 80, 80)); task.wait(2) end
            end
        end

        if reply then
            -- Проверяем не просит ли ИИ запомнить что-то
            local memFact = reply:match("^Запомнил: (.+)")
            if memFact then
                addMemory(memFact)
            end
            table.insert(chatHistory, {role = "user", content = userMsg})
            table.insert(chatHistory, {role = "assistant", content = reply})
            while #chatHistory > 20 do table.remove(chatHistory, 1) end
            onReply(reply)
        else
            onReply("Не удалось получить ответ. Проверь ключи в Настройках.")
        end
        aiWorking = false
        -- Обрабатываем очередь античита если есть
        if #anticheatQueue > 0 then
            local next = table.remove(anticheatQueue, 1)
            task.wait(0.5)
            askAI(next.msg, next.onReply, next.onStatus)
        end
    end)
end

-- Отдельная функция для репортов античита — не блокирует пользователя
local function askAIAnticheat(userMsg, onReply, onStatus)
    if aiWorking then
        -- Добавляем в очередь, но не больше 3 штук чтобы не спамить
        if #anticheatQueue < 3 then
            table.insert(anticheatQueue, {msg=userMsg, onReply=onReply, onStatus=onStatus})
        end
        return
    end
    askAI(userMsg, onReply, onStatus)
end

