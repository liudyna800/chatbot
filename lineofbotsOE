-- ANTICHEAT: детектор скорости
-- =============================================
-- Порог скоростей Piggy Build Mode:
-- Piggy: 13 | Выживший ходьба: 15 | Выживший бег: 21
-- <= 14  — норма (джойстик, медленная ходьба)
-- 15-21  — норма если держится < 5 сек
-- 15-21  — ЧИТ если держится >= 5 сек непрерывно
-- > 21   — сразу ЧИТ (независимо от времени)

local WALK_MAX = 15.5        -- буфер: 15.5 и ниже норма (ходьба=15, флуктуации до 15.5 ок)
local SPRINT_MAX = 21.5      -- буфер: выше 21.5 = сразу чит (21 это норм бег)
local SPRINT_CHEAT_TIME = 5  -- секунд непрерывного спринта = чит
local FLY_CHEAT_TIME = 3      -- секунд в воздухе без Freefall/Jump = флай

-- Состояния слежки за каждым игроком
local playerWatch = {}
-- playerWatch[userId] = {
--   sprintStart   = tick() или nil,  -- таймер спринта
--   airStart      = tick() или nil,  -- таймер нахождения в воздухе (флай)
--   flagged       = false,
--   flaggedFly    = false,
--   flagCount     = 0,
-- }

local addChatMsgGlobal = nil  -- будет задан после GUI
local onCheatDetected = nil   -- callback

local function getHorizontalSpeed(player)
    -- Получаем скорость по горизонтали, игнорируем вертикальную (падение/прыжок)
    local char = player.Character
    if not char then return 0 end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return 0 end
    local vel = hrp.Velocity
    return math.sqrt(vel.X^2 + vel.Z^2)
end

local function getHumanoidState(player)
    local char = player.Character
    if not char then return nil end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return nil end
    return hum:GetState()
end

-- Фоновый мониторинг скоростей
task.spawn(function()
    while true do
        task.wait(0.25)
        for _, player in ipairs(Players:GetPlayers()) do
            if player == Players.LocalPlayer then continue end

            local uid = player.UserId
            if not playerWatch[uid] then
                playerWatch[uid] = {sprintStart = nil, airStart = nil, flagged = false, flaggedFly = false, flagCount = 0}
            end

            local pw = playerWatch[uid]
            if pw.flagged and pw.flaggedFly then continue end

            local speed = getHorizontalSpeed(player)
            local state = getHumanoidState(player)

            -- Определяем состояния
            local isJumping = state == Enum.HumanoidStateType.Jumping
            local isFreefall = state == Enum.HumanoidStateType.Freefall
            local isNormalAir = isJumping or isFreefall  -- обычный прыжок/падение

            -- === ФЛАЙ ДЕТЕКТ ===
            -- Вариант 1: FloorMaterial == Air + не Freefall/Jump + Y vel ~0 (завис)
            -- Вариант 2: Y позиция не меняется >0.5 юнитов за 3 сек пока в воздухе
            if not pw.flaggedFly then
                local char_ = player.Character
                local hrp_ = char_ and char_:FindFirstChild("HumanoidRootPart")
                local hum_ = char_ and char_:FindFirstChildOfClass("Humanoid")
                if hrp_ and hum_ then
                    local yVel = hrp_.Velocity.Y
                    local yPos = hrp_.Position.Y
                    local floorMat = hum_.FloorMaterial
                    local onGround = floorMat ~= Enum.Material.Air

                    -- Вариант 1: завис в воздухе (Y vel небольшой, не на земле, не прыжок/падение)
                    -- порог 4 — при обычном падении yVel намного больше (>10)
                    local suspectV1 = not onGround and not isNormalAir and math.abs(yVel) < 4

                    -- Вариант 2: Y позиция не меняется >0.5 за интервал пока не на земле и не падает
                    local suspectV2 = false
                    if not onGround and not isNormalAir then
                        if pw.flyLastY == nil then
                            pw.flyLastY = yPos
                            pw.flyLastYTick = tick()
                        else
                            local dy = math.abs(yPos - pw.flyLastY)
                            local dt = tick() - pw.flyLastYTick
                            if dt >= 1.0 then  -- проверяем раз в секунду
                                suspectV2 = dy < 1.5  -- при флае Y почти не меняется, при падении >10
                                pw.flyLastY = yPos
                                pw.flyLastYTick = tick()
                            end
                        end
                    else
                        pw.flyLastY = nil
                        pw.flyLastYTick = nil
                    end

                    local isSuspectFly = suspectV1 or suspectV2

                    if isSuspectFly then
                        if pw.airStart == nil then
                            pw.airStart = tick()
                        elseif tick() - pw.airStart >= FLY_CHEAT_TIME then
                            pw.flaggedFly = true
                            if onCheatDetected then
                                onCheatDetected(player, speed, "FLY")
                            end
                        end
                    else
                        pw.airStart = nil
                    end
                end
            end

            -- Для спид-чека игнорируем воздух
            if isNormalAir then
                pw.sprintStart = nil
                continue
            end

            -- === СКОРОСТЬ ДЕТЕКТ ===
            if not pw.flagged then
                if speed > SPRINT_MAX then
                    pw.flagCount = pw.flagCount + 1
                    if pw.flagCount >= 3 then
                        pw.flagged = true
                        if onCheatDetected then
                            onCheatDetected(player, speed, "SPEED_OVER_MAX")
                        end
                    end
                elseif speed > WALK_MAX then
                    pw.flagCount = 0
                    if pw.sprintStart == nil then
                        pw.sprintStart = tick()
                    else
                        local elapsed = tick() - pw.sprintStart
                        if elapsed >= SPRINT_CHEAT_TIME then
                            pw.flagged = true
                            if onCheatDetected then
                                onCheatDetected(player, speed, "SPEED_SUSTAINED")
                            end
                        end
                    end
                else
                    pw.sprintStart = nil
                    pw.flagCount = 0
                end
            end
        end

        -- Чистим вышедших игроков
        for uid in pairs(playerWatch) do
            local found = false
            for _, p in ipairs(Players:GetPlayers()) do
                if p.UserId == uid then found = true; break end
            end
            if not found then playerWatch[uid] = nil end
        end
    end
end)

