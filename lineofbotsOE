local function SendChat(msg)
    if not msg or msg == "" then return end
    -- чанки по 200 символов
    local chunks = SafeSplit(msg, 190)
    for i, chunk in ipairs(chunks) do
        if i > 1 then task.wait(1.2) end
        local ok, err = pcall(function()
            local ch = GetGeneralChannel()
            if ch then
                LastSentMsg = chunk
                ch:SendAsync(chunk)
            else
                warn("[LOB] RBXGeneral not found")
            end
        end)
        if not ok then warn("[LOB] SendChat error: " .. tostring(err)) end
    end
end

