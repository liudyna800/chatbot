-- v17: CAMERA LOOK SYSTEM
-- Бот плавно поворачивает голову/тело к говорящему игроку
-- НЕ работает во время: ходьбы, прыжков, спина
-- ═══════════════════════════════════════════════════════════════════════════

local _cameraLookThread        = nil
local _cameraLookTimeoutThread = nil  -- аварийный таймаут

local function _clearCameraThread()
    _cameraLookThread = nil
    if _cameraLookTimeoutThread then
        pcall(task.cancel, _cameraLookTimeoutThread)
        _cameraLookTimeoutThread = nil
    end
end

local function smoothLookAt(targetPos)
    if not ClientSettings.CameraLook then return end
    -- Проверяем ОБЕ системы движения: старую (_isFollowing) и новую (FollowManager)
    if _isFollowing or _isGoing or _isJumping or _isSpinning then return end
    if FollowManager and FollowManager.Active then return end

    local root = getLocalRootPart()
    if not root then return end

    -- Отменяем предыдущий поворот
    if _cameraLookThread then
        pcall(task.cancel, _cameraLookThread)
        _clearCameraThread()
    end

    -- Аварийный таймаут: через 3 сек флаг сбросится в любом случае
    _cameraLookTimeoutThread = task.delay(3, _clearCameraThread)

    _cameraLookThread = task.spawn(function()
        local duration = 0.4
        local dt       = 0.04
        local elapsed  = 0

        while elapsed < duration do
            if _isFollowing or _isGoing or _isJumping or _isSpinning then break end

            local r = getLocalRootPart()
            if not r then break end

            local dir = (targetPos - r.Position) * Vector3.new(1, 0, 1)
            if dir.Magnitude < 0.5 then break end

            local targetCF = CFrame.new(r.Position, r.Position + dir.Unit)
            local alpha = math.min(dt / (duration - elapsed + 0.001), 1)
            -- pcall на CFrame write — если персонаж уничтожен не падаем
            pcall(function() r.CFrame = r.CFrame:Lerp(targetCF, alpha) end)

            elapsed = elapsed + dt
            task.wait(dt)
        end

        -- Финальная фиксация — точный поворот
        if not (_isFollowing or _isGoing or _isJumping or _isSpinning) then
            local r = getLocalRootPart()
            if r then
                local dir = (targetPos - r.Position) * Vector3.new(1, 0, 1)
                if dir.Magnitude >= 0.5 then
                    pcall(function()
                        r.CFrame = CFrame.new(r.Position, r.Position + dir.Unit)
                    end)
                end
            end
        end

        _clearCameraThread()
    end)
end

