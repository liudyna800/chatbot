local function stopCurrentEmote()
    if _activeEmoteThread then
        pcall(task.cancel, _activeEmoteThread)
        _activeEmoteThread = nil
    end
    if _activeEmoteTrack then
        pcall(function() _activeEmoteTrack:Stop(0.3) end)
        _activeEmoteTrack = nil
    end
    -- Дополнительно: останавливаем все Action-треки через Animator
    local hum = getLocalHumanoid()
    local animator = hum and hum:FindFirstChildOfClass("Animator")
    if animator then
        pcall(function()
            for _, t in ipairs(animator:GetPlayingAnimationTracks()) do
                if t.Priority == Enum.AnimationPriority.Action
                or t.Priority == Enum.AnimationPriority.Action2
                or t.Priority == Enum.AnimationPriority.Action3
                or t.Priority == Enum.AnimationPriority.Action4 then
                    t:Stop(0.3)
                end
            end
        end)
