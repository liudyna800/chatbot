task.delay(5, function()
    local prevAir    = {}
    local prevRadius = {}
    local enterTime  = {}
    local GRACE      = 8

    Players.PlayerRemoving:Connect(function(p)
        local uid = p.UserId
        prevAir[uid]    = nil
        prevRadius[uid] = nil
        enterTime[uid]  = nil
    end)

    while true do
        task.wait(0.5)
        if not ClientSettings.WorldReactions or not ClientSettings.Enabled then
            task.wait(5); continue
        end
        local myChar = Players.LocalPlayer.Character
        local myRoot = myChar and (myChar:FindFirstChild("HumanoidRootPart") or myChar:FindFirstChild("Torso"))
        if not myRoot then continue end
        local myPos  = myRoot.Position
        local radius = ClientSettings.Range.Enabled and ClientSettings.Range.Studs or 30

        for _, p in ipairs(Players:GetPlayers()) do
            if p == Players.LocalPlayer then continue end
            local char     = p.Character
            local uid      = p.UserId
            local root     = char and char:FindFirstChild("HumanoidRootPart")
            local inRadius = root and (root.Position - myPos).Magnitude <= radius

            if inRadius and not prevRadius[uid] then
                enterTime[uid] = os.clock()
            end

            if not inRadius then
                prevRadius[uid] = false
                prevAir[uid]    = false
            else
                prevRadius[uid] = true

                local timeInRadius = os.clock() - (enterTime[uid] or 0)
                local _skipRest = false
                if timeInRadius < GRACE then
                    local hum2 = char:FindFirstChildOfClass("Humanoid")
                    local st2  = hum2 and hum2:GetState()
                    prevAir[uid] = (st2 == Enum.HumanoidStateType.Jumping or st2 == Enum.HumanoidStateType.Freefall)
                    _skipRest = true
                end
                if not _skipRest then
                    local reacted = false
                    local hum     = char:FindFirstChildOfClass("Humanoid")
                    local humState = hum and hum:GetState()
                    local inAir   = humState == Enum.HumanoidStateType.Jumping
                                 or humState == Enum.HumanoidStateType.Freefall

                    if inAir and not prevAir[uid] and _canWorldReact(uid, "jump") then
                        reacted = true
                        local name = p.DisplayName or p.Name
                        local msgs = {
                            "[SYSTEM: "..name.." just jumped near you. React naturally in 1 short sentence.]",
                            "[SYSTEM: "..name.." is jumping around next to you. Notice it briefly.]",
                        }
                        local wKey = uid + 20000000
                        enqueueChatItem(wKey, {
                            player=p, userId=uid, name=p.Name,
                            displayName=name, cleaned=msgs[math.random(#msgs)],
                            isWorld=true,
                        }, 1)
                        runChatQueue(wKey)
                    end
                    prevAir[uid] = inAir

                    if not reacted then
                        local toUs      = myPos - root.Position
                        local stareDist = toUs.Magnitude
                        if stareDist > 1 and root.CFrame.LookVector:Dot(toUs.Unit) > 0.93 then
                            if _canWorldReact(uid, "stare") then
                                local name = p.DisplayName or p.Name
                                local msgs = {
                                    "[SYSTEM: "..name.." is staring right at you. React naturally in 1 short sentence, stay in character.]",
                                    "[SYSTEM: "..name.." keeps looking at you. React briefly, stay in character.]",
                                }
                                local wKey = uid + 20000000
                                enqueueChatItem(wKey, {
                                    player=p, userId=uid, name=p.Name,
                                    displayName=name, cleaned=msgs[math.random(#msgs)],
                                    isWorld=true,
                                }, 2)
                                runChatQueue(wKey)
                            end
                        end
                    end
                end -- if not _skipRest
            end -- else (inRadius)
        end -- for players
    end -- while
